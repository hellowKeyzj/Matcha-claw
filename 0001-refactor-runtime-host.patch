diff --git a/src/components/runtime/useAppBootstrapCoordinator.ts b/src/components/runtime/useAppBootstrapCoordinator.ts
new file mode 100644
index 00000000..4156b819
--- /dev/null
+++ b/src/components/runtime/useAppBootstrapCoordinator.ts
@@ -0,0 +1,300 @@
+import { useEffect, useRef } from 'react';
+import { useGatewayStore } from '@/stores/gateway';
+import { useAppBootstrapStore } from '@/stores/app-bootstrap';
+import { scheduleIdleReady } from '@/lib/idle-ready';
+import { isGatewayOperational } from '@/lib/gateway-status';
+import { scheduleRouteWarmup } from '@/lib/app-warmup';
+import { teamsBackgroundOrchestrator } from '@/features/teams/runtime/orchestrator';
+import { taskCenterRouteOrchestrator } from '@/features/tasks/runtime/task-center-route-orchestrator';
+import { teamChatViewportOrchestrator } from '@/features/teams/runtime/team-chat-viewport-orchestrator';
+import { chatTaskInboxOrchestrator } from '@/features/chat/runtime/chat-task-inbox-orchestrator';
+import { useSettingsStore } from '@/stores/settings';
+import { useLicenseStore } from '@/stores/license';
+import { useUpdateStore } from '@/stores/update';
+import { applyGatewayTransportPreference } from '@/lib/api-client';
+import { requestRendererDomainIntent } from '@/lib/renderer-domain-snapshots';
+
+interface UseAppBootstrapCoordinatorInput {
+  pathname: string;
+  settingsInitialized: boolean;
+  setupComplete: boolean;
+}
+
+export function useAppBootstrapCoordinator(input: UseAppBootstrapCoordinatorInput): void {
+  const { pathname, settingsInitialized, setupComplete } = input;
+  const gatewayStatus = useGatewayStore((state) => state.status);
+  const gatewayOperational = isGatewayOperational(gatewayStatus);
+  const routeWarmupCancelRef = useRef<(() => void) | null>(null);
+  const previousGatewayOperationalRef = useRef(gatewayOperational);
+
+  useEffect(() => {
+    let disposed = false;
+    const bootstrapStore = useAppBootstrapStore.getState();
+
+    applyGatewayTransportPreference();
+
+    bootstrapStore.markRunning('settings', 'app-start');
+    void useSettingsStore.getState().init().then(() => {
+      if (disposed) {
+        return;
+      }
+      bootstrapStore.markReady('settings', 'app-start');
+    }).catch((error) => {
+      if (disposed) {
+        return;
+      }
+      bootstrapStore.markError(
+        'settings',
+        'app-start',
+        error instanceof Error ? error.message : String(error),
+      );
+    });
+
+    bootstrapStore.markRunning('license', 'app-start');
+    void useLicenseStore.getState().init().then(() => {
+      if (disposed) {
+        return;
+      }
+      bootstrapStore.markReady('license', 'app-start');
+    }).catch((error) => {
+      if (disposed) {
+        return;
+      }
+      bootstrapStore.markError(
+        'license',
+        'app-start',
+        error instanceof Error ? error.message : String(error),
+      );
+    });
+
+    bootstrapStore.markRunning('updates', 'app-start');
+    void useUpdateStore.getState().init().then(() => {
+      if (disposed) {
+        return;
+      }
+      bootstrapStore.markReady('updates', 'app-start');
+    }).catch((error) => {
+      if (disposed) {
+        return;
+      }
+      bootstrapStore.markError(
+        'updates',
+        'app-start',
+        error instanceof Error ? error.message : String(error),
+      );
+    });
+
+    return () => {
+      disposed = true;
+    };
+  }, []);
+
+  const extractVisibleTeamId = (path: string): string | null => {
+    const segments = path.split('/').filter(Boolean);
+    if (segments[0] !== 'teams' || segments.length < 2) {
+      return null;
+    }
+    const teamId = segments[1]?.trim();
+    return teamId ? decodeURIComponent(teamId) : null;
+  };
+
+  useEffect(() => {
+    let disposed = false;
+    const bootstrapStore = useAppBootstrapStore.getState();
+    bootstrapStore.markRunning('gateway', 'app-start');
+    void useGatewayStore.getState().init().then(() => {
+      if (disposed) {
+        return;
+      }
+      bootstrapStore.markReady('gateway', 'app-start');
+    }).catch((error) => {
+      if (disposed) {
+        return;
+      }
+      bootstrapStore.markError(
+        'gateway',
+        'app-start',
+        error instanceof Error ? error.message : String(error),
+      );
+    });
+
+    return () => {
+      disposed = true;
+    };
+  }, []);
+
+  useEffect(() => {
+    routeWarmupCancelRef.current?.();
+    routeWarmupCancelRef.current = scheduleRouteWarmup(pathname, {
+      reason: settingsInitialized ? 'route-enter' : 'app-start',
+      dataWarmupsEnabled: settingsInitialized && setupComplete,
+    });
+    return () => {
+      routeWarmupCancelRef.current?.();
+      routeWarmupCancelRef.current = null;
+    };
+  }, [gatewayOperational, pathname, settingsInitialized, setupComplete]);
+
+  useEffect(() => {
+    if (!settingsInitialized || !setupComplete) {
+      previousGatewayOperationalRef.current = gatewayOperational;
+      return;
+    }
+
+    const requestProviders = (intent: 'focus' | 'online' | 'visibility' | 'gateway-ready') => {
+      void requestRendererDomainIntent('providers', { intent });
+    };
+
+    const requestLicense = (intent: 'focus' | 'online' | 'visibility' | 'gateway-ready') => {
+      void requestRendererDomainIntent('license', { intent });
+    };
+
+    const handleFocus = () => {
+      requestProviders('focus');
+      requestLicense('focus');
+    };
+
+    const handleOnline = () => {
+      requestProviders('online');
+      requestLicense('online');
+    };
+
+    const handleVisibilityChange = () => {
+      if (document.visibilityState !== 'visible') {
+        return;
+      }
+      requestProviders('visibility');
+      requestLicense('visibility');
+    };
+
+    window.addEventListener('focus', handleFocus);
+    window.addEventListener('online', handleOnline);
+    document.addEventListener('visibilitychange', handleVisibilityChange);
+
+    const visibleLicenseTimer = window.setInterval(() => {
+      if (document.visibilityState !== 'visible') {
+        return;
+      }
+      requestLicense('visibility');
+    }, 30_000);
+
+    if (!previousGatewayOperationalRef.current && gatewayOperational) {
+      requestProviders('gateway-ready');
+      requestLicense('gateway-ready');
+    }
+    previousGatewayOperationalRef.current = gatewayOperational;
+
+    return () => {
+      window.removeEventListener('focus', handleFocus);
+      window.removeEventListener('online', handleOnline);
+      document.removeEventListener('visibilitychange', handleVisibilityChange);
+      window.clearInterval(visibleLicenseTimer);
+    };
+  }, [gatewayOperational, settingsInitialized, setupComplete]);
+
+  useEffect(() => {
+    if (!settingsInitialized || !setupComplete || !gatewayOperational) {
+      teamsBackgroundOrchestrator.stop();
+      return;
+    }
+
+    const bootstrapStore = useAppBootstrapStore.getState();
+    const cancel = scheduleIdleReady(() => {
+      bootstrapStore.markRunning('teams-runtime', 'gateway-ready');
+      try {
+        teamsBackgroundOrchestrator.start();
+        bootstrapStore.markReady('teams-runtime', 'gateway-ready');
+      } catch (error) {
+        bootstrapStore.markError(
+          'teams-runtime',
+          'gateway-ready',
+          error instanceof Error ? error.message : String(error),
+        );
+      }
+    }, {
+      idleTimeoutMs: 1_200,
+      fallbackDelayMs: 140,
+      useAnimationFrame: true,
+    });
+
+    return () => {
+      cancel();
+      teamsBackgroundOrchestrator.stop();
+    };
+  }, [gatewayOperational, settingsInitialized, setupComplete]);
+
+  useEffect(() => {
+    if (!settingsInitialized || !setupComplete || !gatewayOperational || pathname !== '/tasks') {
+      taskCenterRouteOrchestrator.stop();
+      return;
+    }
+    const bootstrapStore = useAppBootstrapStore.getState();
+    bootstrapStore.markRunning('task-center-runtime', 'route-active');
+    try {
+      taskCenterRouteOrchestrator.start();
+      bootstrapStore.markReady('task-center-runtime', 'route-active');
+    } catch (error) {
+      bootstrapStore.markError(
+        'task-center-runtime',
+        'route-active',
+        error instanceof Error ? error.message : String(error),
+      );
+    }
+    return () => {
+      taskCenterRouteOrchestrator.stop();
+    };
+  }, [gatewayOperational, pathname, settingsInitialized, setupComplete]);
+
+  useEffect(() => {
+    const visibleTeamId = extractVisibleTeamId(pathname);
+    if (!settingsInitialized || !setupComplete || !gatewayOperational || !visibleTeamId) {
+      teamChatViewportOrchestrator.stop();
+      return;
+    }
+    const bootstrapStore = useAppBootstrapStore.getState();
+    bootstrapStore.markRunning('team-chat-viewport', 'route-active');
+    try {
+      teamChatViewportOrchestrator.start(visibleTeamId);
+      bootstrapStore.markReady('team-chat-viewport', 'route-active');
+    } catch (error) {
+      bootstrapStore.markError(
+        'team-chat-viewport',
+        'route-active',
+        error instanceof Error ? error.message : String(error),
+      );
+    }
+    return () => {
+      teamChatViewportOrchestrator.stop();
+    };
+  }, [gatewayOperational, pathname, settingsInitialized, setupComplete]);
+
+  useEffect(() => {
+    if (!settingsInitialized || !setupComplete || !gatewayOperational || pathname !== '/') {
+      chatTaskInboxOrchestrator.stop();
+      return;
+    }
+    const bootstrapStore = useAppBootstrapStore.getState();
+    let disposed = false;
+    bootstrapStore.markRunning('chat-task-inbox-runtime', 'route-active');
+    void requestRendererDomainIntent('task-inbox', { intent: 'route' }).then(() => {
+      if (disposed) {
+        return;
+      }
+      chatTaskInboxOrchestrator.start();
+      bootstrapStore.markReady('chat-task-inbox-runtime', 'route-active');
+    }).catch((error) => {
+      if (disposed) {
+        return;
+      }
+      bootstrapStore.markError(
+        'chat-task-inbox-runtime',
+        'route-active',
+        error instanceof Error ? error.message : String(error),
+      );
+    });
+    return () => {
+      disposed = true;
+      chatTaskInboxOrchestrator.stop();
+    };
+  }, [gatewayOperational, pathname, settingsInitialized, setupComplete]);
+}
