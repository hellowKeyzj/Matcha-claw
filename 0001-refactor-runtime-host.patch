+    const socket = FakeWebSocket.instances[0];
+    expect(socket).toBeTruthy();
+    socket.emit('open');
+    socket.emitJson({
+      type: 'event',
+      event: 'connect.challenge',
+      payload: { nonce: 'nonce-recover-1' },
+    });
+
+    const connectRequest = socket.sentMessages.find((message) => message.method === 'connect');
+    expect(connectRequest).toBeTruthy();
+
+    socket.emitJson({
+      type: 'res',
+      id: connectRequest?.id,
+      ok: true,
+      payload: { hello: 'ok' },
+    });
+
+    await new Promise((resolve) => setTimeout(resolve, 0));
+
+    socket.emitJson({
+      type: 'event',
+      event: 'presence',
+      payload: {},
+    });
+
+    await expect(failingRpc).rejects.toThrow('Gateway RPC timeout: channels.status');
+
+    const recoveredSnapshot = await client.readGatewayConnectionState();
+    expect(recoveredSnapshot.healthSummary).toBe('healthy');
+    expect(recoveredSnapshot.diagnostics.consecutiveRpcFailures).toBe(0);
+    expect(recoveredSnapshot.diagnostics.lastRpcFailureAt).toBeUndefined();
+    expect(recoveredSnapshot.lastIssue).toBeUndefined();
+
+    client.close();
+  });
 });
