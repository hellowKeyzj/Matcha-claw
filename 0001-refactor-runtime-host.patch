@@ -0,0 +1,47 @@
+import { describe, expect, it } from 'vitest';
+import {
+  createHostApiRequestGovernance,
+  resolveHostApiRoutePolicy,
+} from '../../electron/api/hostapi-request-governor';
+
+describe('hostapi request governor', () => {
+  it('用同一张策略表识别 runtime-host 只读 POST 快照路由', () => {
+    const sessionPolicy = resolveHostApiRoutePolicy('POST', '/api/session/load');
+    expect(sessionPolicy.snapshotMode).toBe('snapshot');
+    expect(sessionPolicy.requestClass).toBe('interactive');
+    expect(sessionPolicy.coalesce).toBe(true);
+
+    const teamPolicy = resolveHostApiRoutePolicy('POST', '/api/team-runtime/snapshot');
+    expect(teamPolicy.snapshotMode).toBe('snapshot');
+    expect(teamPolicy.requestClass).toBe('interactive');
+    expect(teamPolicy.coalesce).toBe(true);
+  });
+
+  it('默认把未知 POST 作为 mutation 准入', () => {
+    const policy = resolveHostApiRoutePolicy('POST', '/api/unknown/write');
+    expect(policy.snapshotMode).toBe('mutation');
+    expect(policy.requestClass).toBe('mutation');
+    expect(policy.coalesce).toBe(false);
+  });
+
+  it('cron 列表区分快照读和权威刷新准入', () => {
+    const snapshotPolicy = resolveHostApiRoutePolicy('GET', '/api/cron/jobs');
+    expect(snapshotPolicy.snapshotMode).toBe('snapshot');
+    expect(snapshotPolicy.requestClass).toBe('background');
+    expect(snapshotPolicy.coalesce).toBe(true);
