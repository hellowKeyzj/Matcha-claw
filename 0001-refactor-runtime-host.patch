diff --git a/tests/unit/hostapi-request-admission.test.ts b/tests/unit/hostapi-request-admission.test.ts
new file mode 100644
index 00000000..e8aad303
--- /dev/null
+++ b/tests/unit/hostapi-request-admission.test.ts
@@ -0,0 +1,111 @@
+import { describe, expect, it } from 'vitest';
+import {
+  HostApiAdmissionRejectedError,
+  createHostApiRequestAdmissionController,
+} from '../../electron/main/ipc/hostapi-request-admission';
+
+function deferred<T>() {
+  let resolve!: (value: T | PromiseLike<T>) => void;
+  const promise = new Promise<T>((innerResolve) => {
+    resolve = innerResolve;
+  });
+  return { promise, resolve };
+}
+
+describe('hostapi request admission', () => {
+  it('background 请求会给 interactive 请求让路', async () => {
+    const admission = createHostApiRequestAdmissionController();
+    const backgroundGate = deferred<string>();
+    const events: string[] = [];
+
+    const backgroundTask = admission.run(
+      { requestClass: 'background', maxQueueSize: 1 },
+      async () => {
+        events.push('background:start');
+        return await backgroundGate.promise;
+      },
+    );
+
+    const interactiveTasks = Array.from({ length: 6 }, (_, index) => admission.run(
+      { requestClass: 'interactive', maxQueueSize: 64 },
+      async () => {
+        events.push(`interactive:${index}`);
+        return index;
+      },
+    ));
+
+    const seventhInteractive = admission.run(
+      { requestClass: 'interactive', maxQueueSize: 64 },
+      async () => {
+        events.push('interactive:queued');
+        return 999;
+      },
+    );
+
+    backgroundGate.resolve('background:done');
+    const results = await Promise.all([...interactiveTasks, seventhInteractive, backgroundTask]);
+
+    expect(results).toContain(999);
+    expect(events.indexOf('interactive:queued')).toBeGreaterThanOrEqual(0);
+  });
+
+  it('background 队列满时直接拒绝', async () => {
+    const admission = createHostApiRequestAdmissionController();
+    const gate = deferred<void>();
+
+    void admission.run(
+      { requestClass: 'background', maxQueueSize: 1 },
+      async () => {
+        await gate.promise;
+      },
+    );
+
+    void admission.run(
+      { requestClass: 'background', maxQueueSize: 1 },
+      async () => 1,
+    );
+
+    await expect(admission.run(
+      { requestClass: 'background', maxQueueSize: 1 },
+      async () => 2,
+    )).rejects.toThrow(HostApiAdmissionRejectedError);
+
+    gate.resolve();
+  });
+
+  it('background 队列允许按策略丢弃最旧请求', async () => {
+    const admission = createHostApiRequestAdmissionController();
+    const gate = deferred<void>();
+
+    void admission.run(
+      { requestClass: 'background', maxQueueSize: 1 },
+      async () => {
+        await gate.promise;
+      },
+    );
+
+    const dropped = admission.run(
+      {
+        requestClass: 'background',
+        maxQueueSize: 1,
+        overflow: 'drop-oldest-background',
+      },
+      async () => 1,
+    );
+
+    const kept = admission.run(
+      {
+        requestClass: 'background',
+        maxQueueSize: 1,
+        overflow: 'drop-oldest-background',
+      },
+      async () => 2,
+    );
+
+    await expect(dropped).rejects.toThrow(HostApiAdmissionRejectedError);
+    expect(admission.snapshot().queued.background).toBe(1);
+
+    gate.resolve();
+    await expect(kept).resolves.toBe(2);
+  });
+});
