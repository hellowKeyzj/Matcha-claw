+    minGapMs: 15_000,
+    matches: (context) => shouldRunDataWarmup(context)
+      && context.gatewayOperational
+      && pathStartsWith(context.path, '/security'),
+    key: () => 'security-audits',
+    run: async () => ensureRendererDomainSnapshot('security-audits', { intent: 'route' }),
