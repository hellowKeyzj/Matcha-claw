+
+function buildTeamRuntimeSnapshotKey(input: RuntimeDomainTeamRuntimeSnapshotInput): string {
+  return [
+    input.teamId,
+    input.mailboxCursor ?? '',
+    input.mailboxLimit === undefined ? '' : String(input.mailboxLimit),
+  ].join('|');
+}
+
+function normalizeTeamRuntimeMailboxInput(payload: unknown): RuntimeDomainTeamRuntimeMailboxInput {
+  const body = isRecord(payload) ? payload : {};
+  return {
+    teamId: normalizeRequiredString(body.teamId, 'teamId'),
+    cursor: normalizeOptionalString(body.cursor),
+    limit: normalizePositiveNumber(body.limit, 'limit'),
+  };
+}
+
+function buildTeamRuntimeMailboxKey(input: RuntimeDomainTeamRuntimeMailboxInput): string {
+  return [
+    input.teamId,
+    input.cursor ?? '',
+    input.limit === undefined ? '' : String(input.limit),
+  ].join('|');
+}
+
+export function createRuntimeDomainRegistry(
+  deps: RuntimeDomainRegistryDeps,
