diff --git a/electron/main/ipc/hostapi-request-admission.ts b/electron/main/ipc/hostapi-request-admission.ts
new file mode 100644
index 00000000..fdfb38b4
--- /dev/null
+++ b/electron/main/ipc/hostapi-request-admission.ts
@@ -0,0 +1,171 @@
+export type HostApiAdmissionRequestClass = 'interactive' | 'mutation' | 'background';
+export type HostApiAdmissionOverflow = 'reject' | 'drop-oldest-background';
+
+export interface HostApiAdmissionPolicy {
+  id?: string;
+  requestClass: HostApiAdmissionRequestClass;
+  maxQueueSize: number;
+  overflow?: HostApiAdmissionOverflow;
+}
+
+interface QueuedTask<T> {
+  policy: HostApiAdmissionPolicy;
+  resolve: (value: T | PromiseLike<T>) => void;
+  reject: (reason?: unknown) => void;
+  task: () => Promise<T>;
+}
+
+export class HostApiAdmissionRejectedError extends Error {
+  readonly code = 'HOSTAPI_ADMISSION_REJECTED';
+
+  constructor(message: string) {
+    super(message);
+  }
+}
+
+export interface HostApiRequestAdmissionController {
+  run: <T>(policy: HostApiAdmissionPolicy, task: () => Promise<T>) => Promise<T>;
+  snapshot: () => {
+    active: {
+      total: number;
+      background: number;
+    };
+    queued: Record<HostApiAdmissionRequestClass, number>;
+  };
+}
+
+export function createHostApiRequestAdmissionController(): HostApiRequestAdmissionController {
+  const maxConcurrent = 6;
+  const maxBackgroundConcurrent = 1;
+  let activeTotal = 0;
+  let activeBackground = 0;
+  const mutationQueue: Array<QueuedTask<unknown>> = [];
+  const interactiveQueue: Array<QueuedTask<unknown>> = [];
+  const backgroundQueue: Array<QueuedTask<unknown>> = [];
+
+  function canStart(requestClass: HostApiAdmissionRequestClass): boolean {
+    if (activeTotal >= maxConcurrent) {
+      return false;
+    }
+    if (requestClass === 'background') {
+      if (interactiveQueue.length > 0) {
+        return false;
+      }
+      if (mutationQueue.length > 0) {
+        return false;
+      }
+      return activeBackground < maxBackgroundConcurrent;
+    }
+    return true;
+  }
+
+  function onSettled(requestClass: HostApiAdmissionRequestClass): void {
+    activeTotal = Math.max(0, activeTotal - 1);
+    if (requestClass === 'background') {
+      activeBackground = Math.max(0, activeBackground - 1);
+    }
+    tryDrain();
+  }
+
+  function startQueuedTask<T>(
+    requestClass: HostApiAdmissionRequestClass,
+    entry: QueuedTask<T>,
+  ): void {
+    activeTotal += 1;
+    if (requestClass === 'background') {
+      activeBackground += 1;
+    }
+    void entry.task()
+      .then(entry.resolve, entry.reject)
+      .finally(() => {
+        onSettled(requestClass);
+      });
+  }
+
+  function tryDrain(): void {
+    while (activeTotal < maxConcurrent) {
+      const mutationEntry = mutationQueue.shift();
+      if (mutationEntry) {
+        startQueuedTask('mutation', mutationEntry);
+        continue;
+      }
+      const interactiveEntry = interactiveQueue.shift();
+      if (interactiveEntry) {
+        startQueuedTask('interactive', interactiveEntry);
+        continue;
+      }
+      if (activeBackground >= maxBackgroundConcurrent) {
+        return;
+      }
+      const backgroundEntry = backgroundQueue.shift();
+      if (!backgroundEntry) {
+        return;
+      }
+      startQueuedTask('background', backgroundEntry);
+    }
+  }
+
+  function resolveQueue(policy: HostApiAdmissionPolicy): Array<QueuedTask<unknown>> {
+    if (policy.requestClass === 'background') {
+      return backgroundQueue;
+    }
+    return policy.requestClass === 'mutation' ? mutationQueue : interactiveQueue;
+  }
+
+  function enqueue<T>(policy: HostApiAdmissionPolicy, entry: QueuedTask<T>): void {
+    const queue = resolveQueue(policy);
+    if (queue.length < policy.maxQueueSize) {
+      queue.push(entry as QueuedTask<unknown>);
+      return;
+    }
+
+    if (policy.requestClass === 'background' && policy.overflow === 'drop-oldest-background') {
+      const dropped = queue.shift();
+      dropped?.reject(new HostApiAdmissionRejectedError(
+        `Host API ${policy.requestClass} queue dropped oldest request`,
+      ));
+      queue.push(entry as QueuedTask<unknown>);
+      return;
+    }
+
+    throw new HostApiAdmissionRejectedError(
+      `Host API ${policy.requestClass} queue is full`,
+    );
+  }
+
+  return {
+    run<T>(policy: HostApiAdmissionPolicy, task: () => Promise<T>): Promise<T> {
+      if (canStart(policy.requestClass)) {
+        activeTotal += 1;
+        if (policy.requestClass === 'background') {
+          activeBackground += 1;
+        }
+        return task().finally(() => {
+          onSettled(policy.requestClass);
+        });
+      }
+
+      return new Promise<T>((resolve, reject) => {
+        enqueue(policy, {
+          policy,
+          resolve,
+          reject,
+          task,
+        });
+      });
+    },
+    snapshot() {
+      return {
+        active: {
+          total: activeTotal,
+          background: activeBackground,
+        },
+        queued: {
+          mutation: mutationQueue.length,
+          interactive: interactiveQueue.length,
+          background: backgroundQueue.length,
+        },
+      };
+    },
+  };
+}
