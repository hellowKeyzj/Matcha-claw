@@ -0,0 +1,736 @@
+import {
+  mergePluginCatalogSnapshots,
+} from '../application/plugins/catalog';
+import {
+  ensureConfiguredManagedPluginsInstalled,
+  listEnabledPluginIdsFromConfig,
+  listRuntimePluginCatalog,
+  setRuntimeEnabledPluginIds,
+} from '../application/plugins/runtime-plugin-service';
+import { createSharedKeyedLoader, createSharedLoader } from './shared-loader';
+import type { HeavyTaskPool } from './heavy-task-pool';
+import type { ProviderAccountsService } from '../application/providers/accounts';
+import type { SessionRuntimeService } from '../application/sessions/service';
+import type { createSecurityRuntimeService } from '../application/security/service';
+import type { createTeamRuntimeService } from '../application/team-runtime/service';
+import type { OpenClawBridge } from '../openclaw-bridge';
+import { normalizeCronJob, parseGatewayCronJobs } from '../application/cron/service';
+
+export interface RuntimeDomainPluginSnapshot {
+  enabledPluginIds: string[];
+  pluginCatalog: Array<Record<string, any>>;
+}
+
+export interface RuntimeDomainOpenClawSnapshot {
+  status: {
+    packageExists: boolean;
+    isBuilt: boolean;
+    entryPath: string;
+    dir: string;
+    version?: string;
+  };
+  config: Record<string, unknown>;
+  dirPath: string;
+  configDir: string;
+}
+
+export interface RuntimeDomainCatalogEntry {
+  id: string;
+  name: string;
+  emoji?: string;
+  summary?: string;
+  categoryId?: string;
+  subcategoryId?: string;
+  order?: number;
+  sourcePath?: string;
+  files: Array<'AGENTS.md' | 'SOUL.md' | 'TOOLS.md' | 'IDENTITY.md' | 'USER.md'>;
+}
+
+export interface RuntimeDomainTemplateCatalogSnapshot {
+  sourceDir?: string;
+  categories: Array<{ id: string; order?: number }>;
+  templates: RuntimeDomainCatalogEntry[];
+}
+
+export interface RuntimeDomainTemplateDetailSnapshot {
+  sourceDir?: string;
+  template: RuntimeDomainCatalogEntry & {
+    fileContents: Partial<Record<'AGENTS.md' | 'SOUL.md' | 'TOOLS.md' | 'IDENTITY.md' | 'USER.md', string>>;
+  };
+}
+
+export type RuntimeDomainProviderSnapshot = {
+  accounts: unknown[];
+  statuses: unknown[];
+  vendors: unknown;
+  defaultAccountId: string | null;
+};
+
+export type RuntimeDomainSessionCatalogSnapshot = {
+  sessions: unknown[];
+};
+
+export type RuntimeDomainCronJobsSnapshot = unknown[];
+
+export interface RuntimeDomainChannelsSnapshot {
+  snapshot: unknown;
+  configuredTypes: string[];
+}
+
+export interface RuntimeDomainSecurityRuleCatalogSnapshot {
+  success?: boolean;
+  total?: number;
+  items?: unknown[];
+}
+
+export interface RuntimeDomainTeamRuntimeSnapshotInput {
+  teamId: string;
+  mailboxCursor?: string;
+  mailboxLimit?: number;
+}
+
+export interface RuntimeDomainTeamRuntimeMailboxInput {
+  teamId: string;
+  cursor?: string;
+  limit?: number;
+}
+
+export type RuntimeDomainReadinessState = 'idle' | 'warming' | 'ready';
+
+export interface RuntimeSnapshotDomain<TValue> {
+  peekSnapshot: () => TValue | undefined;
+  readSnapshot: () => Promise<TValue>;
+  readFreshSnapshot: () => Promise<TValue>;
+  refreshAuthoritative: () => Promise<TValue>;
+  refreshInBackground: () => void;
+  invalidate: () => void;
+}
+
+export interface RuntimeWritableSnapshotDomain<TValue> extends RuntimeSnapshotDomain<TValue> {
+  setSnapshot: (value: TValue) => TValue;
+}
+
+export interface RuntimeInputSnapshotDomain<TInput, TValue> {
+  readSnapshot: (input: TInput) => Promise<TValue>;
+  readFreshSnapshot: (input: TInput) => Promise<TValue>;
+  refreshAuthoritative: (input: TInput) => Promise<TValue>;
+  refreshInBackground: (input: TInput) => void;
+  invalidate: (input?: TInput) => void;
+}
+
+export interface RuntimeDomainRegistry {
+  plugins: RuntimeSnapshotDomain<RuntimeDomainPluginSnapshot> & {
+    setEnabledPluginIds: (pluginIds: readonly string[]) => Promise<RuntimeDomainPluginSnapshot>;
+  };
+  openclaw: RuntimeSnapshotDomain<RuntimeDomainOpenClawSnapshot>;
+  subagentTemplates: {
+    catalog: RuntimeSnapshotDomain<RuntimeDomainTemplateCatalogSnapshot>;
+    detail: RuntimeInputSnapshotDomain<string, RuntimeDomainTemplateDetailSnapshot | null>;
+  };
+  providers?: RuntimeSnapshotDomain<RuntimeDomainProviderSnapshot>;
+  sessions?: RuntimeSnapshotDomain<RuntimeDomainSessionCatalogSnapshot>;
+  cronJobs: RuntimeSnapshotDomain<RuntimeDomainCronJobsSnapshot>;
+  channels: RuntimeSnapshotDomain<RuntimeDomainChannelsSnapshot>;
+  security?: {
+    policy: RuntimeWritableSnapshotDomain<unknown>;
+    ruleCatalog: RuntimeInputSnapshotDomain<string | null | undefined, RuntimeDomainSecurityRuleCatalogSnapshot>;
+    audit: RuntimeInputSnapshotDomain<URL, unknown>;
+  };
+  teamRuntime?: {
+    snapshot: RuntimeInputSnapshotDomain<unknown, unknown>;
+    mailbox: RuntimeInputSnapshotDomain<unknown, unknown>;
+    invalidateTeam: (teamId?: string) => void;
+  };
+  getReadinessSnapshot: () => Record<string, RuntimeDomainReadinessState>;
+}
+
+interface RuntimeDomainRegistryDeps {
+  getOpenClawStatus: () => RuntimeDomainOpenClawSnapshot['status'];
+  readOpenClawConfigJson: () => Record<string, unknown>;
+  getOpenClawDirPath: () => string;
+  getOpenClawConfigDir: () => string;
+  getSubagentTemplateCatalogFromSources: () => RuntimeDomainTemplateCatalogSnapshot;
+  getSubagentTemplateFromSources: (templateId: string) => RuntimeDomainTemplateDetailSnapshot | null;
+  injectedPluginCatalog: Array<Record<string, any>>;
+  fallbackEnabledPluginIds: string[];
+  providerService?: ProviderAccountsService;
+  sessionService?: SessionRuntimeService;
+  openclawBridge: Pick<OpenClawBridge, 'listCronJobs'>;
+  securityService?: ReturnType<typeof createSecurityRuntimeService>;
+  teamRuntimeService?: ReturnType<typeof createTeamRuntimeService>;
+  heavyTaskPool?: HeavyTaskPool;
+  readChannelSnapshot: () => Promise<unknown>;
+  listConfiguredChannels: () => Promise<string[]>;
+}
+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return Boolean(value) && typeof value === 'object' && !Array.isArray(value);
+}
+
+function normalizeRequiredString(value: unknown, fieldName: string): string {
+  const normalized = typeof value === 'string' ? value.trim() : '';
+  if (!normalized) {
+    throw new Error(`${fieldName} is required`);
+  }
+  return normalized;
+}
+
+function normalizeOptionalString(value: unknown): string | undefined {
+  return typeof value === 'string' ? value : undefined;
+}
+
+function normalizePositiveNumber(value: unknown, fieldName: string): number | undefined {
+  if (value == null) {
+    return undefined;
+  }
+  const numeric = Number(value);
+  if (!Number.isFinite(numeric) || numeric <= 0) {
+    throw new Error(`${fieldName} must be a positive number`);
+  }
+  return Math.floor(numeric);
+}
+
+function normalizeSecurityQueryKey(routeUrl: URL): string {
+  const pairs = Array.from(routeUrl.searchParams.entries())
+    .filter(([, value]) => value.trim().length > 0)
+    .sort(([leftKey, leftValue], [rightKey, rightValue]) => {
+      if (leftKey === rightKey) {
+        return leftValue.localeCompare(rightValue);
+      }
+      return leftKey.localeCompare(rightKey);
+    });
+  return new URLSearchParams(pairs).toString();
+}
+
+function createSecurityAuditUrl(queryKey: string): URL {
+  return new URL(
+    queryKey.length > 0
+      ? `http://127.0.0.1/api/security/audit?${queryKey}`
