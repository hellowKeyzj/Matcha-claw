+              refreshAuthoritative: async (payload: unknown) => {
+                const input = normalizeTeamRuntimeSnapshotInput(payload);
+                return await teamRuntimeSnapshotLoader.refreshAuthoritative(buildTeamRuntimeSnapshotKey(input));
+              },
+              refreshInBackground: (payload: unknown) => {
+                const input = normalizeTeamRuntimeSnapshotInput(payload);
+                teamRuntimeSnapshotLoader.refreshInBackground(buildTeamRuntimeSnapshotKey(input));
+              },
+              invalidate: () => {
+                teamRuntimeSnapshotLoader.invalidate();
+              },
+            },
+            mailbox: {
