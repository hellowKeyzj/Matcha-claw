diff --git a/src/stores/subagent-template-store.ts b/src/stores/subagent-template-store.ts
new file mode 100644
index 00000000..ca5916e7
--- /dev/null
+++ b/src/stores/subagent-template-store.ts
@@ -0,0 +1,83 @@
+import { create } from 'zustand';
+import {
+  getSubagentTemplateCatalog,
+} from '@/services/openclaw/subagent-template-catalog';
+import type { SubagentTemplateCatalogResult } from '@/types/subagent';
+
+interface SubagentTemplateStoreState {
+  catalog: SubagentTemplateCatalogResult;
+  snapshotReady: boolean;
+  initialLoading: boolean;
+  refreshing: boolean;
+  error: string | null;
+  init: (options?: { force?: boolean; silent?: boolean }) => Promise<void>;
+}
+
+const EMPTY_TEMPLATE_CATALOG: SubagentTemplateCatalogResult = {
+  categories: [],
+  templates: [],
+};
+
+let inflightTemplateCatalogInit: Promise<void> | null = null;
+
+export const useSubagentTemplateStore = create<SubagentTemplateStoreState>((set, get) => ({
+  catalog: EMPTY_TEMPLATE_CATALOG,
+  snapshotReady: false,
+  initialLoading: false,
+  refreshing: false,
+  error: null,
+
+  init: async (options) => {
+    const force = options?.force === true;
+    const silent = options?.silent === true;
+    if (!force && get().snapshotReady) {
+      return;
+    }
+    if (inflightTemplateCatalogInit) {
+      await inflightTemplateCatalogInit;
+      return;
+    }
+
+    if (!get().snapshotReady) {
+      set({
+        initialLoading: true,
+        refreshing: false,
+        error: null,
+      });
+    } else if (!silent) {
+      set({
+        initialLoading: false,
+        refreshing: true,
+        error: null,
+      });
+    }
+
+    const task = (async () => {
+      try {
+        const catalog = await getSubagentTemplateCatalog();
+        set({
+          catalog,
+          snapshotReady: true,
+          initialLoading: false,
+          refreshing: false,
+          error: null,
+        });
+      } catch (error) {
+        set({
+          initialLoading: false,
+          refreshing: false,
+          error: error instanceof Error ? error.message : String(error),
+        });
+      }
+    })();
+
+    inflightTemplateCatalogInit = task;
+    try {
+      await task;
+    } finally {
+      if (inflightTemplateCatalogInit === task) {
+        inflightTemplateCatalogInit = null;
+      }
+    }
+  },
+}));
