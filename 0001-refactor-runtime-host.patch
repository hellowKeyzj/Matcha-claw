+export function isRendererDomainReady(domain: RendererDomainId, context?: RendererDomainContext): boolean {
+  return rendererDomainContracts[domain].isReady(context);
+}
+
+export async function ensureRendererDomainSnapshot(
+  domain: RendererDomainId,
+  context?: RendererDomainContext,
