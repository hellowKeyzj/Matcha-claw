+                  return;
+                }
+                securityRuleCatalogLoader.invalidate();
+              },
+            },
+            audit: {
+              readSnapshot: async (routeUrl: URL) => await securityAuditLoader.readSnapshot(
+                normalizeSecurityQueryKey(routeUrl),
+              ),
+              readFreshSnapshot: async (routeUrl: URL) => await securityAuditLoader.readFreshSnapshot(
+                normalizeSecurityQueryKey(routeUrl),
+              ),
+              refreshAuthoritative: async (routeUrl: URL) => await securityAuditLoader.refreshAuthoritative(
+                normalizeSecurityQueryKey(routeUrl),
+              ),
+              refreshInBackground: (routeUrl: URL) => {
+                securityAuditLoader.refreshInBackground(normalizeSecurityQueryKey(routeUrl));
+              },
+              invalidate: (routeUrl?: URL) => {
