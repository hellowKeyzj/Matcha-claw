diff --git a/src/features/teams/runtime/team-chat-viewport-orchestrator.ts b/src/features/teams/runtime/team-chat-viewport-orchestrator.ts
new file mode 100644
index 00000000..5ea2e4b4
--- /dev/null
+++ b/src/features/teams/runtime/team-chat-viewport-orchestrator.ts
@@ -0,0 +1,114 @@
+import { isGatewayOperational } from '@/lib/gateway-status';
+import { requestRendererDomainIntent } from '@/lib/renderer-domain-snapshots';
+import { useGatewayStore } from '@/stores/gateway';
+import { useTeamsStore } from '@/stores/teams';
+
+const SNAPSHOT_REFRESH_ACTIVE_MS = 3_000;
+const SNAPSHOT_REFRESH_IDLE_MS = 10_000;
+const SNAPSHOT_REFRESH_BACKGROUND_MS = 25_000;
+
+function hasTeamWorkload(teamId: string): boolean {
+  const tasks = useTeamsStore.getState().tasksByTeamId[teamId] ?? [];
+  return tasks.some((task) => (
+    task.status === 'todo'
+    || task.status === 'claimed'
+    || task.status === 'running'
+    || task.status === 'blocked'
+  ));
+}
+
+export class TeamChatViewportOrchestrator {
+  private timer: ReturnType<typeof setTimeout> | null = null;
+  private running = false;
+  private currentTeamId: string | null = null;
+  private visibilityHandlerBound = false;
+
+  private handleVisibilityChange = () => {
+    if (!this.running || !this.currentTeamId) {
+      return;
+    }
+    this.scheduleNextTick(0);
+  };
+
+  private isDocumentVisible(): boolean {
+    if (typeof document === 'undefined') {
+      return true;
+    }
+    return document.visibilityState === 'visible';
+  }
+
+  private resolveTickDelayMs(teamId: string): number {
+    if (!this.isDocumentVisible()) {
+      return SNAPSHOT_REFRESH_BACKGROUND_MS;
+    }
+    return hasTeamWorkload(teamId) ? SNAPSHOT_REFRESH_ACTIVE_MS : SNAPSHOT_REFRESH_IDLE_MS;
+  }
+
+  private scheduleNextTick(delayMs?: number): void {
+    if (!this.running || !this.currentTeamId) {
+      return;
+    }
+    if (this.timer) {
+      clearTimeout(this.timer);
+    }
+    const teamId = this.currentTeamId;
+    this.timer = setTimeout(() => {
+      void this.tick(teamId).finally(() => {
+        if (this.currentTeamId === teamId) {
+          this.scheduleNextTick();
+        }
+      });
+    }, typeof delayMs === 'number' ? delayMs : this.resolveTickDelayMs(teamId));
+  }
+
+  private async tick(teamId: string): Promise<void> {
+    if (!this.running || this.currentTeamId !== teamId) {
+      return;
+    }
+    if (!isGatewayOperational(useGatewayStore.getState().status)) {
+      return;
+    }
+    const store = useTeamsStore.getState();
+    await store.ensureRuntimeReady(teamId);
+    await Promise.all([
+      requestRendererDomainIntent('team-runtime-current', {
+        path: `/teams/${encodeURIComponent(teamId)}`,
+        intent: 'route',
+      }),
+      store.pullMailbox(teamId, 50),
+    ]);
+  }
+
+  start(teamId: string): void {
+    const normalizedTeamId = teamId.trim();
+    if (!normalizedTeamId) {
+      this.stop();
+      return;
+    }
+    const needsRestart = !this.running || this.currentTeamId !== normalizedTeamId;
+    this.currentTeamId = normalizedTeamId;
+    if (!this.visibilityHandlerBound && typeof document !== 'undefined') {
+      document.addEventListener('visibilitychange', this.handleVisibilityChange);
+      this.visibilityHandlerBound = true;
+    }
+    this.running = true;
+    if (needsRestart) {
+      this.scheduleNextTick(0);
+    }
+  }
+
+  stop(): void {
+    this.running = false;
+    this.currentTeamId = null;
+    if (this.timer) {
+      clearTimeout(this.timer);
+      this.timer = null;
+    }
+    if (this.visibilityHandlerBound && typeof document !== 'undefined') {
+      document.removeEventListener('visibilitychange', this.handleVisibilityChange);
+      this.visibilityHandlerBound = false;
+    }
+  }
+}
+
+export const teamChatViewportOrchestrator = new TeamChatViewportOrchestrator();
