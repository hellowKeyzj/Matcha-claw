diff --git a/runtime-host/api/heavy-task-pool.ts b/runtime-host/api/heavy-task-pool.ts
new file mode 100644
index 00000000..fc2c1641
--- /dev/null
+++ b/runtime-host/api/heavy-task-pool.ts
@@ -0,0 +1,179 @@
+type HeavyTaskLaneId =
+  | 'plugins'
+  | 'providers'
+  | 'sessions'
+  | 'templates'
+  | 'openclaw'
+  | 'cron'
+  | 'channels'
+  | 'security'
+  | 'team_runtime';
+
+export type HeavyTaskPriority = 'interactive' | 'background';
+
+export interface HeavyTaskLaneSnapshot {
+  readonly active: number;
+  readonly interactiveQueued: number;
+  readonly backgroundQueued: number;
+  readonly maxConcurrent: number;
+}
+
+export interface HeavyTaskPoolSnapshot {
+  readonly activeTotal: number;
+  readonly maxConcurrent: number;
+  readonly lanes: Record<HeavyTaskLaneId, HeavyTaskLaneSnapshot>;
+}
+
+interface LaneState {
+  active: number;
+  interactiveQueue: Array<() => void>;
+  backgroundQueue: Array<() => void>;
+}
+
+interface HeavyTaskPoolOptions {
+  maxConcurrent?: number;
+  laneConcurrency?: Partial<Record<HeavyTaskLaneId, number>>;
+}
+
+function createLaneState(): LaneState {
+  return {
+    active: 0,
+    interactiveQueue: [],
+    backgroundQueue: [],
+  };
+}
+
+export interface HeavyTaskPool {
+  schedule: <T>(
+    lane: HeavyTaskLaneId,
+    task: () => Promise<T>,
+    options?: { priority?: HeavyTaskPriority },
+  ) => Promise<T>;
+  canScheduleImmediately: (priority: HeavyTaskPriority) => boolean;
+  snapshot: () => HeavyTaskPoolSnapshot;
+}
+
+export function createHeavyTaskPool(options: HeavyTaskPoolOptions = {}): HeavyTaskPool {
+  const maxConcurrent = Math.max(1, options.maxConcurrent ?? 3);
+  const laneConcurrency: Record<HeavyTaskLaneId, number> = {
+    plugins: Math.max(1, options.laneConcurrency?.plugins ?? 1),
+    providers: Math.max(1, options.laneConcurrency?.providers ?? 1),
+    sessions: Math.max(1, options.laneConcurrency?.sessions ?? 1),
+    templates: Math.max(1, options.laneConcurrency?.templates ?? 1),
+    openclaw: Math.max(1, options.laneConcurrency?.openclaw ?? 2),
+    cron: Math.max(1, options.laneConcurrency?.cron ?? 1),
+    channels: Math.max(1, options.laneConcurrency?.channels ?? 1),
+    security: Math.max(1, options.laneConcurrency?.security ?? 1),
+    team_runtime: Math.max(1, options.laneConcurrency?.team_runtime ?? 1),
+  };
+  const laneStates = new Map<HeavyTaskLaneId, LaneState>();
+  let activeTotal = 0;
+
+  function getLaneState(lane: HeavyTaskLaneId): LaneState {
+    let state = laneStates.get(lane);
+    if (!state) {
+      state = createLaneState();
+      laneStates.set(lane, state);
+    }
+    return state;
+  }
+
+  function tryDequeue(): void {
+    if (activeTotal >= maxConcurrent) {
+      return;
+    }
+
+    for (const lane of Object.keys(laneConcurrency) as HeavyTaskLaneId[]) {
+      const state = getLaneState(lane);
+      const nextQueue = state.interactiveQueue.length > 0
+        ? state.interactiveQueue
+        : state.backgroundQueue;
+      if (nextQueue.length === 0) {
+        continue;
+      }
+      if (state.active >= laneConcurrency[lane]) {
+        continue;
+      }
+      const next = nextQueue.shift();
+      if (!next) {
+        continue;
+      }
+      next();
+      if (activeTotal >= maxConcurrent) {
+        return;
+      }
+    }
+  }
+
+  return {
+    schedule<T>(
+      lane: HeavyTaskLaneId,
+      task: () => Promise<T>,
+      options?: { priority?: HeavyTaskPriority },
+    ): Promise<T> {
+      return new Promise<T>((resolve, reject) => {
+        const laneState = getLaneState(lane);
+        const priority = options?.priority === 'background' ? 'background' : 'interactive';
+        const run = () => {
+          laneState.active += 1;
+          activeTotal += 1;
+          void task().then(resolve, reject).finally(() => {
+            laneState.active = Math.max(0, laneState.active - 1);
+            activeTotal = Math.max(0, activeTotal - 1);
+            tryDequeue();
+          });
+        };
+
+        if (activeTotal < maxConcurrent && laneState.active < laneConcurrency[lane]) {
+          run();
+          return;
+        }
+
+        if (priority === 'background') {
+          laneState.backgroundQueue.push(run);
+          return;
+        }
+        laneState.interactiveQueue.push(run);
+      });
+    },
+    canScheduleImmediately(priority) {
+      if (priority === 'interactive') {
+        return activeTotal < maxConcurrent;
+      }
+      return activeTotal < maxConcurrent && activeBackgroundEligible(laneStates, laneConcurrency);
+    },
+    snapshot() {
+      const lanes = {} as Record<HeavyTaskLaneId, HeavyTaskLaneSnapshot>;
+      for (const lane of Object.keys(laneConcurrency) as HeavyTaskLaneId[]) {
+        const state = getLaneState(lane);
+        lanes[lane] = {
+          active: state.active,
+          interactiveQueued: state.interactiveQueue.length,
+          backgroundQueued: state.backgroundQueue.length,
+          maxConcurrent: laneConcurrency[lane],
+        };
+      }
+      return {
+        activeTotal,
+        maxConcurrent,
+        lanes,
+      };
+    },
+  };
+}
+
+function activeBackgroundEligible(
+  laneStates: Map<HeavyTaskLaneId, LaneState>,
+  laneConcurrency: Record<HeavyTaskLaneId, number>,
+): boolean {
+  for (const lane of Object.keys(laneConcurrency) as HeavyTaskLaneId[]) {
+    const state = laneStates.get(lane);
+    if (!state) {
+      continue;
+    }
+    if (state.interactiveQueue.length > 0) {
+      return false;
+    }
+  }
+  return true;
+}
