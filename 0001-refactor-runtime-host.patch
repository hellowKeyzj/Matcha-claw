+  const teamRuntimeMailboxLoader = deps.teamRuntimeService
+    ? createSharedKeyedLoader<string, unknown>(
+        async (mailboxKey) => {
+          const [teamId, cursor, limitRaw] = mailboxKey.split('|');
+          return await deps.teamRuntimeService!.mailboxPull({
+            teamId,
+            ...(cursor ? { cursor } : {}),
+            ...(limitRaw ? { limit: Number(limitRaw) } : {}),
+          });
+        },
+        {
+          minFreshMs: 1_000,
+          allowStaleOnError: true,
+          canScheduleBackground,
+          ...(heavyTaskPool
+            ? {
+                schedule: <T>(task: () => Promise<T>) => heavyTaskPool.schedule('team_runtime', task),
+              }
+            : {}),
+        },
+      )
+    : null;
+
+  function toReadinessState(hasSnapshot: boolean, available: boolean): RuntimeDomainReadinessState {
+    if (!available) {
+      return 'idle';
+    }
+    return hasSnapshot ? 'ready' : 'warming';
+  }
+
+  return {
+    plugins: {
+      peekSnapshot: () => pluginLoader.peek(),
+      readSnapshot: async () => await pluginLoader.readSnapshot(),
+      readFreshSnapshot: async () => await pluginLoader.readFreshSnapshot(),
+      refreshAuthoritative: async () => await pluginLoader.refreshAuthoritative(),
+      refreshInBackground: () => pluginLoader.refreshInBackground(),
+      invalidate: () => pluginLoader.invalidate(),
+      setEnabledPluginIds: async (pluginIds) => {
+        const enabledPluginIds = await setRuntimeEnabledPluginIds(pluginIds);
+        const current = await pluginLoader.refreshAuthoritative();
+        return pluginLoader.set({
+          enabledPluginIds,
+          pluginCatalog: current.pluginCatalog,
+        });
+      },
+    },
+    openclaw: {
+      peekSnapshot: () => openclawLoader.peek(),
+      readSnapshot: async () => await openclawLoader.readSnapshot(),
+      readFreshSnapshot: async () => await openclawLoader.readFreshSnapshot(),
+      refreshAuthoritative: async () => await openclawLoader.refreshAuthoritative(),
+      refreshInBackground: () => openclawLoader.refreshInBackground(),
+      invalidate: () => openclawLoader.invalidate(),
