--- /dev/null
+++ b/src/stores/chat/chat-warmup.ts
@@ -0,0 +1,59 @@
+import { useChatStore } from './store';
+import { getSessionItemCount } from './store-state-helpers';
+
+const inflightSessionWarmByKey = new Map<string, Promise<void>>();
+
+interface EnsureCurrentChatSessionWarmInput {
+  reason: string;
+  quietRefreshWhenReady?: boolean;
+}
+
+export async function ensureCurrentChatSessionWarm(
+  input: EnsureCurrentChatSessionWarmInput,
+): Promise<void> {
+  const state = useChatStore.getState();
+  const sessionKey = state.currentSessionKey.trim();
+  if (!sessionKey) {
+    return;
+  }
+
+  const currentSessionRecord = state.loadedSessions[sessionKey];
+  const hasCurrentViewportSnapshot = (
+    currentSessionRecord?.meta.historyStatus === 'ready'
+    || getSessionItemCount(currentSessionRecord) > 0
+  );
+
+  if (hasCurrentViewportSnapshot) {
+    if (input.quietRefreshWhenReady) {
+      void state.loadHistory({
+        sessionKey,
+        mode: 'quiet',
+        scope: 'foreground',
+        reason: `${input.reason}_quiet_refresh`,
+      });
+    }
+    return;
+  }
+
+  const inflight = inflightSessionWarmByKey.get(sessionKey);
+  if (inflight) {
+    await inflight;
+    return;
+  }
+
+  const task = state.loadHistory({
+    sessionKey,
+    mode: 'active',
+    scope: 'foreground',
+    reason: `${input.reason}_cold_start`,
+  });
+
+  inflightSessionWarmByKey.set(sessionKey, task);
+  try {
+    await task;
+  } finally {
+    if (inflightSessionWarmByKey.get(sessionKey) === task) {
+      inflightSessionWarmByKey.delete(sessionKey);
+    }
+  }
+}
