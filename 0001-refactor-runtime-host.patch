+      context.path === '/'
+      || pathStartsWith(context.path, '/providers')
+      || pathStartsWith(context.path, '/settings')
+      || pathStartsWith(context.path, '/subagents')
+    ),
+    key: () => 'providers',
+    run: async () => ensureRendererDomainSnapshot('providers', { intent: 'route', silent: true }),
+  },
+  {
+    id: 'skills',
+    phase: 'deferred',
+    minGapMs: 15_000,
+    matches: (context) => shouldRunDataWarmup(context)
+      && context.gatewayOperational
+      && (context.path === '/' || pathStartsWith(context.path, '/skills')),
+    key: () => 'skills',
+    run: async () => ensureRendererDomainSnapshot('skills', { intent: 'route', silent: true }),
+  },
+  {
+    id: 'chat-sessions',
+    phase: 'critical',
+    minGapMs: 15_000,
+    matches: (context) => shouldRunDataWarmup(context)
+      && context.gatewayOperational
+      && context.path === '/',
+    key: () => 'chat-sessions',
+    run: async () => ensureRendererDomainSnapshot('chat-sessions', { intent: 'route' }),
+  },
+  {
+    id: 'chat-sessions',
+    phase: 'deferred',
+    minGapMs: 15_000,
+    matches: (context) => shouldRunDataWarmup(context)
+      && context.gatewayOperational
+      && context.path === '/',
+    key: () => 'chat-session-viewport',
+    run: async () => ensureRendererDomainSnapshot('chat-current-viewport', { intent: 'route' }),
+  },
+  {
+    id: 'dashboard-usage',
+    phase: 'deferred',
+    minGapMs: 15_000,
+    matches: (context) => shouldRunDataWarmup(context)
+      && context.gatewayOperational
+      && pathStartsWith(context.path, '/dashboard'),
+    key: (context) => `dashboard-usage:${context.path}:${useGatewayStore.getState().status.pid ?? 'na'}:${useGatewayStore.getState().status.connectedAt ?? 'na'}`,
+    run: async () => ensureRendererDomainSnapshot('dashboard-usage', { intent: 'route' }),
