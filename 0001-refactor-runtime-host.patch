diff --git a/src/pages/Chat/chat-model-view.ts b/src/pages/Chat/chat-model-view.ts
new file mode 100644
index 00000000..727adb58
--- /dev/null
+++ b/src/pages/Chat/chat-model-view.ts
@@ -0,0 +1,92 @@
+import type { ChatSessionRecord } from '@/stores/chat/types';
+import { parseAgentIdFromSessionKey } from '@/stores/chat/session-helpers';
+import type { ModelCatalogEntry, SubagentSummary } from '@/types/subagent';
+
+export interface ChatModelPickerOptionView {
+  id: string;
+  label: string;
+}
+
+export interface ChatModelPickerView {
+  currentModelId: string;
+  currentLabel: string;
+  options: ChatModelPickerOptionView[];
+  loading: boolean;
+  switching: boolean;
+}
+
+export interface ChatCurrentModelView {
+  currentAgentId: string;
+  currentAgent: SubagentSummary | undefined;
+  effectiveModelId: string;
+  modelPicker: ChatModelPickerView | null;
+}
+
+function normalizeModelId(value: string | null | undefined): string {
+  return typeof value === 'string' ? value.trim() : '';
+}
+
+export function resolveEffectiveChatModelId(
+  sessionModel: string | null | undefined,
+  agentDefaultModel: string | null | undefined,
+): string {
+  const normalizedSessionModel = normalizeModelId(sessionModel);
+  if (normalizedSessionModel) {
+    return normalizedSessionModel;
+  }
+  return normalizeModelId(agentDefaultModel);
+}
+
+export function resolveChatCurrentModelView(input: {
+  currentSessionKey: string;
+  currentSession: ChatSessionRecord;
+  agents: SubagentSummary[];
+  availableModels: ModelCatalogEntry[];
+  modelsLoading: boolean;
+}): ChatCurrentModelView {
+  const currentAgentId = parseAgentIdFromSessionKey(input.currentSessionKey) ?? 'main';
+  const currentAgent = input.agents.find((agent) => agent.id === currentAgentId);
+  const effectiveModelId = resolveEffectiveChatModelId(
+    input.currentSession.meta.model,
+    currentAgent?.model,
+  );
+
+  if (!effectiveModelId) {
+    return {
+      currentAgentId,
+      currentAgent,
+      effectiveModelId,
+      modelPicker: null,
+    };
+  }
+
+  const optionLabels = new Map<string, string>();
+  for (const model of input.availableModels) {
+    optionLabels.set(model.id, model.displayLabel);
+  }
+
+  const options = input.availableModels.map((model) => ({
+    id: model.id,
+    label: model.displayLabel,
+  }));
+
+  if (!optionLabels.has(effectiveModelId)) {
+    options.unshift({
+      id: effectiveModelId,
+      label: effectiveModelId,
+    });
+  }
+
+  return {
+    currentAgentId,
+    currentAgent,
+    effectiveModelId,
+    modelPicker: {
+      currentModelId: effectiveModelId,
+      currentLabel: optionLabels.get(effectiveModelId) ?? effectiveModelId,
+      options,
+      loading: input.modelsLoading,
+      switching: false,
+    },
+  };
+}
