+import { isGatewayOperational } from '@/lib/gateway-status';
+import { scheduleIdleReady } from '@/lib/idle-ready';
+import {
+  preloadLazyRouteForPath,
+  preloadRouteNeighborhoodForPath,
+} from '@/lib/route-preload';
+import { prefetchSubagentTemplateCatalog } from '@/services/openclaw/subagent-template-catalog';
+import { useGatewayStore } from '@/stores/gateway';
+import {
+  useAppBootstrapStore,
+  type AppBootstrapDomainId,
+} from '@/stores/app-bootstrap';
+import { ensureRendererDomainSnapshot } from '@/lib/renderer-domain-snapshots';
+
+type RouteWarmupPhase = 'critical' | 'deferred' | 'background';
+type RouteWarmupReason = 'app-start' | 'route-enter' | 'hover';
+
+interface RouteWarmupContext {
+  path: string;
+  reason: RouteWarmupReason;
+  gatewayOperational: boolean;
+  dataWarmupsEnabled: boolean;
+}
+
+interface RouteWarmupTask {
+  id: AppBootstrapDomainId;
+  phase: RouteWarmupPhase;
+  minGapMs: number;
+  matches: (context: RouteWarmupContext) => boolean;
+  key: (context: RouteWarmupContext) => string;
+  run: (context: RouteWarmupContext) => Promise<void> | void;
+}
+
+interface RunRouteWarmupOptions {
+  phases?: RouteWarmupPhase[];
+  reason?: RouteWarmupReason;
+  dataWarmupsEnabled?: boolean;
+}
+
+interface ScheduleRouteWarmupOptions extends RunRouteWarmupOptions {
+  deferredIdleTimeoutMs?: number;
+  backgroundIdleTimeoutMs?: number;
+}
+
+const DEFAULT_RUN_PHASES: RouteWarmupPhase[] = ['critical', 'deferred', 'background'];
+const inflightWarmups = new Map<string, Promise<void>>();
+const lastWarmupAtByKey = new Map<string, number>();
+
+function normalizeRoutePath(path: string): string {
+  if (!path) {
+    return '/';
+  }
+  const [withoutHash] = path.split('#');
+  const [withoutQuery] = withoutHash.split('?');
+  if (!withoutQuery) {
+    return '/';
+  }
+  return withoutQuery.startsWith('/') ? withoutQuery : `/${withoutQuery}`;
+}
+
+function pathStartsWith(path: string, prefix: string): boolean {
+  return path === prefix || path.startsWith(`${prefix}/`);
+}
+
+function extractTeamIdFromPath(path: string): string | null {
+  if (!pathStartsWith(path, '/teams')) {
+    return null;
+  }
+  const segments = path.split('/').filter(Boolean);
+  if (segments[0] !== 'teams' || segments.length < 2) {
+    return null;
+  }
+  const teamId = segments[1]?.trim();
+  return teamId ? decodeURIComponent(teamId) : null;
+}
+
+function buildContext(path: string, options?: RunRouteWarmupOptions): RouteWarmupContext {
+  return {
+    path: normalizeRoutePath(path),
+    reason: options?.reason ?? 'route-enter',
+    gatewayOperational: isGatewayOperational(useGatewayStore.getState().status),
+    dataWarmupsEnabled: options?.dataWarmupsEnabled ?? true,
+  };
+}
+
+function shouldRunDataWarmup(context: RouteWarmupContext): boolean {
+  return context.dataWarmupsEnabled;
+}
+
+const ROUTE_WARMUP_TASKS: RouteWarmupTask[] = [
+  {
+    id: 'license',
+    phase: 'critical',
+    minGapMs: 15_000,
