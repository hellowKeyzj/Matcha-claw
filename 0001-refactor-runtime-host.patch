+    teamId: normalizeRequiredString(body.teamId, 'teamId'),
+    mailboxCursor: normalizeOptionalString(body.mailboxCursor),
+    mailboxLimit: normalizePositiveNumber(body.mailboxLimit, 'mailboxLimit'),
+  };
