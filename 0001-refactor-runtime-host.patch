+              refreshInBackground: (payload: unknown) => {
+                const input = normalizeTeamRuntimeMailboxInput(payload);
+                teamRuntimeMailboxLoader.refreshInBackground(buildTeamRuntimeMailboxKey(input));
+              },
+              invalidate: () => {
+                teamRuntimeMailboxLoader.invalidate();
+              },
+            },
+            invalidateTeam: (teamId?: string) => {
+              if (!teamId) {
+                teamRuntimeSnapshotLoader.invalidate();
+                teamRuntimeMailboxLoader.invalidate();
+                return;
+              }
+              const normalizedTeamId = teamId.trim();
+              if (!normalizedTeamId) {
+                return;
+              }
+              teamRuntimeSnapshotLoader.invalidateWhere((key) => key.startsWith(`${normalizedTeamId}|`));
+              teamRuntimeMailboxLoader.invalidateWhere((key) => key.startsWith(`${normalizedTeamId}|`));
+            },
+          },
+        }
+      : {}),
+    getReadinessSnapshot: () => ({
+      plugins: toReadinessState(pluginLoader.peek() !== undefined, true),
+      openclaw: toReadinessState(openclawLoader.peek() !== undefined, true),
+      subagentTemplates: toReadinessState(templateCatalogLoader.peek() !== undefined, true),
+      providers: toReadinessState(providerLoader?.peek() !== undefined, Boolean(providerLoader)),
+      sessions: toReadinessState(sessionCatalogLoader?.peek() !== undefined, Boolean(sessionCatalogLoader)),
+      cronJobs: toReadinessState(cronJobsLoader.peek() !== undefined, true),
+      channels: toReadinessState(channelsLoader.peek() !== undefined, true),
+      security: toReadinessState(securityPolicyLoader?.peek() !== undefined, Boolean(securityPolicyLoader)),
+      teamRuntime: toReadinessState(false, Boolean(teamRuntimeSnapshotLoader && teamRuntimeMailboxLoader)),
+    }),
+  };
+}
