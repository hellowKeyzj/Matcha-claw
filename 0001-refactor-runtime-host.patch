diff --git a/src/features/chat/runtime/chat-task-inbox-orchestrator.ts b/src/features/chat/runtime/chat-task-inbox-orchestrator.ts
new file mode 100644
index 00000000..b68c6377
--- /dev/null
+++ b/src/features/chat/runtime/chat-task-inbox-orchestrator.ts
@@ -0,0 +1,90 @@
+import { isGatewayOperational } from '@/lib/gateway-status';
+import { ensureRendererDomainSnapshot } from '@/lib/renderer-domain-snapshots';
+import { useGatewayStore } from '@/stores/gateway';
+import { useTaskInboxStore } from '@/stores/task-inbox-store';
+
+const TASK_INBOX_POLL_FAST_MS = 5_000;
+const TASK_INBOX_POLL_NORMAL_MS = 15_000;
+const TASK_INBOX_POLL_BACKGROUND_MS = 60_000;
+
+export class ChatTaskInboxOrchestrator {
+  private timer: ReturnType<typeof setTimeout> | null = null;
+  private running = false;
+  private visibilityHandlerBound = false;
+
+  private handleVisibilityChange = () => {
+    if (!this.running) {
+      return;
+    }
+    this.scheduleNextTick(0);
+  };
+
+  private isDocumentVisible(): boolean {
+    if (typeof document === 'undefined') {
+      return true;
+    }
+    return document.visibilityState === 'visible';
+  }
+
+  private hasActiveTasks(): boolean {
+    const tasks = useTaskInboxStore.getState().tasks;
+    return tasks.some((task) => task.status === 'pending' || task.status === 'in_progress');
+  }
+
+  private resolveTickDelayMs(): number {
+    if (!this.isDocumentVisible()) {
+      return TASK_INBOX_POLL_BACKGROUND_MS;
+    }
+    return this.hasActiveTasks() ? TASK_INBOX_POLL_FAST_MS : TASK_INBOX_POLL_NORMAL_MS;
+  }
+
+  private scheduleNextTick(delayMs?: number): void {
+    if (!this.running) {
+      return;
+    }
+    if (this.timer) {
+      clearTimeout(this.timer);
+    }
+    this.timer = setTimeout(() => {
+      void this.tick().finally(() => {
+        this.scheduleNextTick();
+      });
+    }, typeof delayMs === 'number' ? delayMs : this.resolveTickDelayMs());
+  }
+
+  private async tick(): Promise<void> {
+    if (!this.running) {
+      return;
+    }
+    if (!isGatewayOperational(useGatewayStore.getState().status)) {
+      return;
+    }
+    await ensureRendererDomainSnapshot('task-inbox', { intent: 'route' });
+  }
+
+  start(): void {
+    if (this.running) {
+      return;
+    }
+    this.running = true;
+    if (!this.visibilityHandlerBound && typeof document !== 'undefined') {
+      document.addEventListener('visibilitychange', this.handleVisibilityChange);
+      this.visibilityHandlerBound = true;
+    }
+    this.scheduleNextTick(0);
+  }
+
+  stop(): void {
+    this.running = false;
+    if (this.timer) {
+      clearTimeout(this.timer);
+      this.timer = null;
+    }
+    if (this.visibilityHandlerBound && typeof document !== 'undefined') {
+      document.removeEventListener('visibilitychange', this.handleVisibilityChange);
+      this.visibilityHandlerBound = false;
+    }
+  }
+}
+
+export const chatTaskInboxOrchestrator = new ChatTaskInboxOrchestrator();
