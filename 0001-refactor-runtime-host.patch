+        || pathStartsWith(context.path, '/cron')
+      ),
+    key: () => 'subagents',
+    run: async () => ensureRendererDomainSnapshot('subagents', { intent: 'route', silent: true }),
+  },
+  {
+    id: 'subagent-models',
+    phase: 'deferred',
