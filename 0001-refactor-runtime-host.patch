+export type HostApiMethod = 'GET' | 'POST' | 'PUT' | 'DELETE' | 'HEAD';
+export type HostApiRequestClass = 'interactive' | 'mutation' | 'background';
+export type HostApiAdmissionOverflow = 'reject' | 'drop-oldest-background';
+export type HostApiSnapshotMode = 'snapshot' | 'authoritative' | 'mutation';
+
+export interface HostApiRoutePolicy {
+  id: string;
+  domain: string;
+  matches: (method: HostApiMethod, path: string) => boolean;
+  timeoutMs: number;
+  snapshotMode: HostApiSnapshotMode;
+  requestClass: HostApiRequestClass;
+  coalesce: boolean;
+  maxQueueSize: number;
+  overflow: HostApiAdmissionOverflow;
+}
+
+export interface HostApiRequestGovernance {
+  resolvePolicy: (method: HostApiMethod, path: string) => HostApiRoutePolicy;
+  buildCoalesceKey: (
+    policy: HostApiRoutePolicy,
+    method: HostApiMethod,
+    path: string,
+    body?: string,
+  ) => string | null;
+}
+
+const DEFAULT_HOST_API_TIMEOUT_MS = 15_000;
+const FILE_DIRECTORY_TIMEOUT_MS = 60_000;
+
+function isReadMethod(method: HostApiMethod): boolean {
+  return method === 'GET' || method === 'HEAD';
+}
+
