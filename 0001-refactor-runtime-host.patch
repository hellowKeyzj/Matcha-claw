+    : null;
+
+  const teamRuntimeSnapshotLoader = deps.teamRuntimeService
+    ? createSharedKeyedLoader<string, unknown>(
+        async (snapshotKey) => {
+          const [teamId, mailboxCursor, mailboxLimitRaw] = snapshotKey.split('|');
+          return await deps.teamRuntimeService!.snapshot({
+            teamId,
+            ...(mailboxCursor ? { mailboxCursor } : {}),
+            ...(mailboxLimitRaw ? { mailboxLimit: Number(mailboxLimitRaw) } : {}),
+          });
+        },
+        {
+          minFreshMs: 1_000,
+          allowStaleOnError: true,
+          canScheduleBackground,
+          ...(heavyTaskPool
+            ? {
+                schedule: <T>(task: () => Promise<T>) => heavyTaskPool.schedule('team_runtime', task),
+              }
+            : {}),
+        },
+      )
+    : null;
