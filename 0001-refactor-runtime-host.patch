+  },
+  {
+    id: 'subagent-template-catalog',
+    phase: 'deferred',
+    minGapMs: 15_000,
+    matches: (context) => shouldRunDataWarmup(context)
+      && (
+        context.path === '/'
+        || pathStartsWith(context.path, '/subagents')
+      ),
+    key: () => 'subagent-template-catalog',
+    run: async () => ensureRendererDomainSnapshot('subagent-template-catalog', { intent: 'route', silent: true }),
+  },
+  {
+    id: 'plugins',
+    phase: 'deferred',
+    minGapMs: 15_000,
+    matches: (context) => shouldRunDataWarmup(context)
+      && context.gatewayOperational
+      && (
+        context.path === '/'
+        || pathStartsWith(context.path, '/plugins')
+      ),
+    key: () => 'plugins',
+    run: async () => ensureRendererDomainSnapshot('plugins', { intent: 'route', silent: true }),
+  },
+  {
+    id: 'cron-jobs',
+    phase: 'deferred',
+    minGapMs: 15_000,
+    matches: (context) => shouldRunDataWarmup(context)
+      && context.gatewayOperational
+      && (
+        context.path === '/'
+        || pathStartsWith(context.path, '/tasks')
+        || pathStartsWith(context.path, '/cron')
+      ),
+    key: () => 'cron-jobs',
+    run: async () => ensureRendererDomainSnapshot('cron-jobs', { intent: 'route', silent: true }),
+  },
+  {
+    id: 'security-policy',
+    phase: 'deferred',
+    minGapMs: 15_000,
