+            },
+          },
+        }
+      : {}),
+    ...(teamRuntimeSnapshotLoader && teamRuntimeMailboxLoader
+      ? {
+          teamRuntime: {
+            snapshot: {
+              readSnapshot: async (payload: unknown) => {
+                const input = normalizeTeamRuntimeSnapshotInput(payload);
