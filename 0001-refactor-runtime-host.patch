+    phase: 'deferred',
+    minGapMs: 15_000,
+    matches: (context) => shouldRunDataWarmup(context)
+      && context.gatewayOperational
+      && extractTeamIdFromPath(context.path) !== null,
+    key: (context) => `team-runtime-current:${extractTeamIdFromPath(context.path) ?? 'none'}`,
+    run: async (context) => ensureRendererDomainSnapshot('team-runtime-current', {
+      path: context.path,
+      intent: 'route',
+    }),
+  },
+  {
+    id: 'subagent-templates',
+    phase: 'background',
+    minGapMs: 30_000,
+    matches: (context) => shouldRunDataWarmup(context)
+      && pathStartsWith(context.path, '/subagents'),
+    key: () => 'subagent-templates',
+    run: async () => {
+      await prefetchSubagentTemplateCatalog();
+    },
+  },
+];
+
+async function runWarmupTask(task: RouteWarmupTask, context: RouteWarmupContext): Promise<void> {
+  const key = task.key(context);
+  const now = Date.now();
+  const lastAt = lastWarmupAtByKey.get(key) ?? 0;
+  if (task.minGapMs > 0 && now - lastAt < task.minGapMs) {
+    return;
+  }
+
+  const inflight = inflightWarmups.get(key);
+  if (inflight) {
+    await inflight;
+    return;
+  }
+
+  const store = useAppBootstrapStore.getState();
+  const taskPromise = (async () => {
+    store.markRunning(task.id, context.reason);
+    try {
+      await task.run(context);
+      lastWarmupAtByKey.set(key, Date.now());
+      store.markReady(task.id, context.reason);
+    } catch (error) {
+      const message = error instanceof Error ? error.message : String(error);
+      store.markError(task.id, context.reason, message);
+      throw error;
+    }
+  })();
+
+  inflightWarmups.set(key, taskPromise);
+  try {
+    await taskPromise;
+  } finally {
+    if (inflightWarmups.get(key) === taskPromise) {
+      inflightWarmups.delete(key);
+    }
+  }
+}
+
+export async function runRouteWarmup(path: string, options?: RunRouteWarmupOptions): Promise<void> {
+  const context = buildContext(path, options);
+  const phases = options?.phases ?? DEFAULT_RUN_PHASES;
+  for (const phase of phases) {
+    const phaseTasks = ROUTE_WARMUP_TASKS.filter((task) => task.phase === phase && task.matches(context));
+    for (const task of phaseTasks) {
+      await runWarmupTask(task, context);
+    }
+  }
+}
+
+export function scheduleRouteWarmup(path: string, options?: ScheduleRouteWarmupOptions): () => void {
+  let cancelled = false;
+
+  void runRouteWarmup(path, {
+    ...options,
+    phases: ['critical'],
+  }).catch(() => {});
+
+  const cancelDeferred = scheduleIdleReady(() => {
+    if (cancelled) {
+      return;
+    }
+    void runRouteWarmup(path, {
+      ...options,
+      phases: ['deferred'],
+    }).catch(() => {});
+  }, {
+    idleTimeoutMs: options?.deferredIdleTimeoutMs ?? 900,
+    fallbackDelayMs: 90,
+    useAnimationFrame: true,
+  });
+
+  const cancelBackground = scheduleIdleReady(() => {
+    if (cancelled) {
+      return;
+    }
+    void runRouteWarmup(path, {
+      ...options,
+      phases: ['background'],
+    }).catch(() => {});
+  }, {
+    idleTimeoutMs: options?.backgroundIdleTimeoutMs ?? 3_500,
+    fallbackDelayMs: 220,
+    useAnimationFrame: true,
+  });
+
+  return () => {
+    cancelled = true;
+    cancelDeferred();
+    cancelBackground();
+  };
+}
