+  const canScheduleBackground = () => heavyTaskPool?.canScheduleImmediately('background') ?? true;
+  const pluginLoader = createSharedLoader<RuntimeDomainPluginSnapshot>(async () => {
+    const [configuredEnabledPluginIds, discoveredCatalog] = await Promise.all([
+      ensureConfiguredManagedPluginsInstalled(),
+      listRuntimePluginCatalog(),
+    ]);
+    const enabledPluginIds = configuredEnabledPluginIds.length > 0
+      ? configuredEnabledPluginIds
+      : [...deps.fallbackEnabledPluginIds];
+    return {
+      enabledPluginIds,
+      pluginCatalog: mergePluginCatalogSnapshots(discoveredCatalog, deps.injectedPluginCatalog),
+    };
+  }, {
+    minFreshMs: 10_000,
+    allowStaleOnError: true,
+    canScheduleBackground,
+    ...(heavyTaskPool
+      ? {
+          schedule: <T>(task: () => Promise<T>) => heavyTaskPool.schedule('plugins', task),
+        }
+      : {}),
+    ...(deps.injectedPluginCatalog.length > 0
+      ? {
+          initialValue: {
+            enabledPluginIds: listEnabledPluginIdsFromConfig().length > 0
+              ? listEnabledPluginIdsFromConfig()
+              : [...deps.fallbackEnabledPluginIds],
+            pluginCatalog: [...deps.injectedPluginCatalog],
+          },
+        }
+      : {}),
+  });
+
+  const openclawLoader = createSharedLoader<RuntimeDomainOpenClawSnapshot>(() => ({
+    status: deps.getOpenClawStatus(),
+    config: deps.readOpenClawConfigJson(),
+    dirPath: deps.getOpenClawDirPath(),
+    configDir: deps.getOpenClawConfigDir(),
+  }), {
+    minFreshMs: 2_000,
+    allowStaleOnError: true,
+    canScheduleBackground,
+    ...(heavyTaskPool
+      ? {
+          schedule: <T>(task: () => Promise<T>) => heavyTaskPool.schedule('openclaw', task),
+        }
+      : {}),
+  });
+
+  const templateCatalogLoader = createSharedLoader<RuntimeDomainTemplateCatalogSnapshot>(
+    () => deps.getSubagentTemplateCatalogFromSources(),
+    {
+      minFreshMs: 10_000,
+      allowStaleOnError: true,
+      canScheduleBackground,
+      ...(heavyTaskPool
+        ? {
+            schedule: <T>(task: () => Promise<T>) => heavyTaskPool.schedule('templates', task),
+          }
+        : {}),
+      initialValue: deps.getSubagentTemplateCatalogFromSources(),
+    },
+  );
+  const templateDetailLoader = createSharedKeyedLoader<string, RuntimeDomainTemplateDetailSnapshot | null>(
+    (templateId) => deps.getSubagentTemplateFromSources(templateId),
+    {
+      minFreshMs: 10_000,
+      allowStaleOnError: true,
+      canScheduleBackground,
+      ...(heavyTaskPool
+        ? {
+            schedule: <T>(task: () => Promise<T>) => heavyTaskPool.schedule('templates', task),
+          }
+        : {}),
+    },
+  );
+
+  const providerLoader = deps.providerService
+    ? createSharedLoader<RuntimeDomainProviderSnapshot>(
+        async () => await deps.providerService!.list() as RuntimeDomainProviderSnapshot,
+        {
+          minFreshMs: 5_000,
+          allowStaleOnError: true,
+          canScheduleBackground,
+          ...(heavyTaskPool
+            ? {
+                schedule: <T>(task: () => Promise<T>) => heavyTaskPool.schedule('providers', task),
+              }
+            : {}),
+        },
+      )
+    : null;
+
+  const sessionCatalogLoader = deps.sessionService
+    ? createSharedLoader<RuntimeDomainSessionCatalogSnapshot>(
+        async () => {
+          const result = await deps.sessionService!.listSessions();
+          return result.data as RuntimeDomainSessionCatalogSnapshot;
+        },
+        {
+          minFreshMs: 2_000,
+          allowStaleOnError: true,
+          canScheduleBackground,
+          ...(heavyTaskPool
+            ? {
+                schedule: <T>(task: () => Promise<T>) => heavyTaskPool.schedule('sessions', task),
+              }
+            : {}),
+        },
+      )
+    : null;
+
+  const cronJobsLoader = createSharedLoader<RuntimeDomainCronJobsSnapshot>(
+    async () => {
+      const listResult = await deps.openclawBridge.listCronJobs(true);
+      return parseGatewayCronJobs(listResult).map((job) => normalizeCronJob(job));
+    },
+    {
+      minFreshMs: 2_000,
+      allowStaleOnError: true,
+      initialValue: [],
+      canScheduleBackground,
+      ...(heavyTaskPool
+        ? {
+            schedule: <T>(task: () => Promise<T>, options?: { priority?: 'interactive' | 'background' }) => (
+              heavyTaskPool.schedule('cron', task, options)
+            ),
+          }
+        : {}),
+    },
+  );
+
+  const channelsLoader = createSharedLoader<RuntimeDomainChannelsSnapshot>(
+    async () => {
+      const [snapshot, configuredTypes] = await Promise.all([
+        deps.readChannelSnapshot(),
+        deps.listConfiguredChannels(),
+      ]);
+      return {
+        snapshot,
+        configuredTypes,
+      };
+    },
+    {
+      minFreshMs: 2_000,
+      allowStaleOnError: true,
+      canScheduleBackground,
+      ...(heavyTaskPool
+        ? {
+            schedule: <T>(task: () => Promise<T>) => heavyTaskPool.schedule('channels', task),
+          }
+        : {}),
+    },
+  );
+
+  const securityPolicyLoader = deps.securityService
+    ? createSharedLoader<unknown>(
+        async () => deps.securityService!.readPolicy(),
+        {
+          minFreshMs: 2_000,
+          allowStaleOnError: true,
+          canScheduleBackground,
+          ...(heavyTaskPool
+            ? {
+                schedule: <T>(task: () => Promise<T>) => heavyTaskPool.schedule('security', task),
+              }
+            : {}),
+        },
+      )
+    : null;
+
+  const securityRuleCatalogLoader = deps.securityService
+    ? createSharedKeyedLoader<string, RuntimeDomainSecurityRuleCatalogSnapshot>(
+        async (platformKey) => ({
+          ...deps.securityService!.listRuleCatalog(platformKey === '__all__' ? undefined : platformKey),
+        }),
+        {
+          minFreshMs: 10_000,
+          allowStaleOnError: true,
+          canScheduleBackground,
+          ...(heavyTaskPool
+            ? {
+                schedule: <T>(task: () => Promise<T>) => heavyTaskPool.schedule('security', task),
+              }
+            : {}),
