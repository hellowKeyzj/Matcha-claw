diff --git a/runtime-host/api/runtime-side-effect-coordinator.ts b/runtime-host/api/runtime-side-effect-coordinator.ts
new file mode 100644
index 00000000..75a92bea
--- /dev/null
+++ b/runtime-host/api/runtime-side-effect-coordinator.ts
@@ -0,0 +1,147 @@
+import type { RuntimeDomainRegistry } from './runtime-domains';
+
+type RuntimeMutationRequestClass = 'interactive' | 'mutation' | 'background';
+
+export interface RuntimeSideEffectCoordinator {
+  afterProviderMutation: (requestClass?: RuntimeMutationRequestClass) => void;
+  afterChannelMutation: (requestClass?: RuntimeMutationRequestClass) => void;
+  afterSessionCatalogMutation: (requestClass?: RuntimeMutationRequestClass) => void;
+  afterCronMutation: (requestClass?: RuntimeMutationRequestClass) => void;
+  afterPluginMutation: (requestClass?: RuntimeMutationRequestClass) => void;
+  afterSecurityPolicyMutation: (requestClass?: RuntimeMutationRequestClass) => void;
+  afterSecurityAuditMutation: () => void;
+  afterTeamRuntimeMutation: (teamId?: string | null, requestClass?: RuntimeMutationRequestClass) => void;
+  afterSkillsMutation: (requestClass?: RuntimeMutationRequestClass) => void;
+  afterOpenClawConfigMutation: (requestClass?: RuntimeMutationRequestClass) => void;
+}
+
+type MutationRule = {
+  invalidate: () => void;
+  refresh?: () => void;
+};
+
+export function createRuntimeSideEffectCoordinator(
+  runtimeDomains: RuntimeDomainRegistry,
+): RuntimeSideEffectCoordinator {
+  const mutationRules: Record<string, MutationRule> = {
+    provider: {
+      invalidate: () => {
+        runtimeDomains.providers?.invalidate();
+      },
+      refresh: () => {
+        runtimeDomains.providers?.refreshInBackground();
+      },
+    },
+    channel: {
+      invalidate: () => {
+        runtimeDomains.channels.invalidate();
+        runtimeDomains.openclaw.invalidate();
+        runtimeDomains.plugins.invalidate();
+      },
+      refresh: () => {
+        runtimeDomains.channels.refreshInBackground();
+        runtimeDomains.openclaw.refreshInBackground();
+        runtimeDomains.plugins.refreshInBackground();
+      },
+    },
+    session: {
+      invalidate: () => {
+        runtimeDomains.sessions?.invalidate();
+      },
+      refresh: () => {
+        runtimeDomains.sessions?.refreshInBackground();
+      },
+    },
+    cron: {
+      invalidate: () => {
+        runtimeDomains.cronJobs.invalidate();
+      },
+      refresh: () => {
+        runtimeDomains.cronJobs.refreshInBackground();
+      },
+    },
+    plugin: {
+      invalidate: () => {
+        runtimeDomains.plugins.invalidate();
+        runtimeDomains.openclaw.invalidate();
+      },
+      refresh: () => {
+        runtimeDomains.plugins.refreshInBackground();
+        runtimeDomains.openclaw.refreshInBackground();
+      },
+    },
+    security_policy: {
+      invalidate: () => {
+        runtimeDomains.security?.policy.invalidate();
+        runtimeDomains.security?.audit.invalidate();
+      },
+      refresh: () => {
+        runtimeDomains.security?.policy.refreshInBackground();
+      },
+    },
+    security_audit: {
+      invalidate: () => {
+        runtimeDomains.security?.audit.invalidate();
+      },
+    },
+    skills: {
+      invalidate: () => {
+        runtimeDomains.openclaw.invalidate();
+      },
+      refresh: () => {
+        runtimeDomains.openclaw.refreshInBackground();
+      },
+    },
+    openclaw_config: {
+      invalidate: () => {
+        runtimeDomains.openclaw.invalidate();
+      },
+      refresh: () => {
+        runtimeDomains.openclaw.refreshInBackground();
+      },
+    },
+  };
+
+  function applyMutation(
+    mutation: keyof typeof mutationRules,
+    requestClass?: RuntimeMutationRequestClass,
+  ): void {
+    mutationRules[mutation].invalidate();
+    if (requestClass !== 'background') {
+      mutationRules[mutation].refresh?.();
+    }
+  }
+
+  return {
+    afterProviderMutation(requestClass) {
+      applyMutation('provider', requestClass);
+    },
+    afterChannelMutation(requestClass) {
+      applyMutation('channel', requestClass);
+    },
+    afterSessionCatalogMutation(requestClass) {
+      applyMutation('session', requestClass);
+    },
+    afterCronMutation(requestClass) {
+      applyMutation('cron', requestClass);
+    },
+    afterPluginMutation(requestClass) {
+      applyMutation('plugin', requestClass);
+    },
+    afterSecurityPolicyMutation(requestClass) {
+      applyMutation('security_policy', requestClass);
+    },
+    afterSecurityAuditMutation() {
+      applyMutation('security_audit');
+    },
+    afterTeamRuntimeMutation(teamId) {
+      runtimeDomains.teamRuntime?.invalidateTeam(teamId ?? undefined);
+    },
+    afterSkillsMutation(requestClass) {
+      applyMutation('skills', requestClass);
+    },
+    afterOpenClawConfigMutation(requestClass) {
+      applyMutation('openclaw_config', requestClass);
+    },
+  };
+}
diff --git a/runtime-host/api/shared-loader.ts b/runtime-host/api/shared-loader.ts
new file mode 100644
index 00000000..2b304f42
--- /dev/null
+++ b/runtime-host/api/shared-loader.ts
@@ -0,0 +1,183 @@
+interface SharedLoaderState<TValue> {
+  value?: TValue;
+  loadedAt: number;
+  interactiveInflight: Promise<TValue> | null;
+  backgroundInflight: Promise<TValue> | null;
+}
+
+interface SharedLoaderOptions<TValue> {
+  minFreshMs?: number;
+  allowStaleOnError?: boolean;
+  initialValue?: TValue;
+  canScheduleBackground?: () => boolean;
+  schedule?: <T>(
+    task: () => Promise<T>,
+    options?: { priority?: 'interactive' | 'background' },
+  ) => Promise<T>;
+}
+
+function createInitialState<TValue>(initialValue?: TValue): SharedLoaderState<TValue> {
+  return {
+    value: initialValue,
+    loadedAt: initialValue === undefined ? 0 : Date.now(),
+    interactiveInflight: null,
+    backgroundInflight: null,
+  };
+}
+
+function isFresh(loadedAt: number, minFreshMs: number): boolean {
+  return loadedAt > 0 && (Date.now() - loadedAt) < minFreshMs;
+}
+
+export function createSharedLoader<TValue>(
+  load: () => Promise<TValue> | TValue,
+  options: SharedLoaderOptions<TValue> = {},
+) {
+  let state = createInitialState(options.initialValue);
+  const minFreshMs = Math.max(0, options.minFreshMs ?? 0);
+  const allowStaleOnError = options.allowStaleOnError === true;
+  const canScheduleBackground = options.canScheduleBackground;
+  const schedule = options.schedule;
+
+  async function runLoad(priority: 'interactive' | 'background'): Promise<TValue> {
+    const inflightKey = priority === 'background' ? 'backgroundInflight' : 'interactiveInflight';
+    const existingInflight = state[inflightKey];
+    if (existingInflight) {
+      return await existingInflight;
+    }
+
+    if (priority === 'interactive' && state.backgroundInflight) {
+      return await state.backgroundInflight;
+    }
+
+    const task = (async () => {
+      try {
+        const value = schedule
+          ? await schedule(async () => await load(), { priority })
+          : await load();
+        state = {
+          value,
+          loadedAt: Date.now(),
+          interactiveInflight: null,
+          backgroundInflight: null,
+        };
+        return value;
+      } catch (error) {
+        if (allowStaleOnError && state.value !== undefined) {
+          state = {
+            ...state,
+            [inflightKey]: null,
+          };
+          return state.value;
+        }
+        state = {
+          ...state,
+          [inflightKey]: null,
+        };
+        throw error;
+      }
+    })();
+
+    state = {
+      ...state,
+      [inflightKey]: task,
+    };
+    return await task;
+  }
+
+  return {
+    peek(): TValue | undefined {
+      return state.value;
+    },
+    set(value: TValue): TValue {
+      state = {
+        value,
+        loadedAt: Date.now(),
+        interactiveInflight: null,
+        backgroundInflight: null,
+      };
+      return value;
+    },
+    invalidate(): void {
+      state = {
+        ...state,
+        loadedAt: 0,
+      };
+    },
+    async readSnapshot(): Promise<TValue> {
+      if (state.value !== undefined && state.loadedAt > 0) {
+        return state.value;
+      }
+      return await runLoad('interactive');
+    },
+    async readFreshSnapshot(): Promise<TValue> {
+      if (state.value !== undefined && isFresh(state.loadedAt, minFreshMs)) {
+        return state.value;
+      }
+      return await runLoad('interactive');
+    },
+    async refreshAuthoritative(): Promise<TValue> {
+      return await runLoad('interactive');
+    },
+    refreshInBackground(): void {
+      if (state.backgroundInflight || state.interactiveInflight) {
+        return;
+      }
+      if (canScheduleBackground && !canScheduleBackground()) {
+        return;
+      }
+      void runLoad('background').catch(() => {});
+    },
+  };
+}
+
+export function createSharedKeyedLoader<TKey extends string, TValue>(
+  load: (key: TKey) => Promise<TValue> | TValue,
+  options: Omit<SharedLoaderOptions<TValue>, 'initialValue'> = {},
+) {
+  const loaders = new Map<TKey, ReturnType<typeof createSharedLoader<TValue>>>();
+
+  function getLoader(key: TKey) {
+    let loader = loaders.get(key);
+    if (!loader) {
+      loader = createSharedLoader(() => load(key), options);
+      loaders.set(key, loader);
+    }
+    return loader;
+  }
+
+  return {
+    peek(key: TKey): TValue | undefined {
+      return loaders.get(key)?.peek();
+    },
+    set(key: TKey, value: TValue): TValue {
+      return getLoader(key).set(value);
+    },
+    invalidate(key?: TKey): void {
+      if (key === undefined) {
+        loaders.clear();
+        return;
+      }
+      loaders.get(key)?.invalidate();
+    },
+    invalidateWhere(predicate: (key: TKey) => boolean): void {
+      for (const key of loaders.keys()) {
+        if (predicate(key)) {
+          loaders.delete(key);
+        }
+      }
+    },
+    async readSnapshot(key: TKey): Promise<TValue> {
+      return await getLoader(key).readSnapshot();
+    },
+    async readFreshSnapshot(key: TKey): Promise<TValue> {
+      return await getLoader(key).readFreshSnapshot();
+    },
+    async refreshAuthoritative(key: TKey): Promise<TValue> {
+      return await getLoader(key).refreshAuthoritative();
+    },
+    refreshInBackground(key: TKey): void {
+      getLoader(key).refreshInBackground();
+    },
+  };
+}
