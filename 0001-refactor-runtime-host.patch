@@ -0,0 +1,243 @@
+import type { RuntimeHostManager } from '../main/runtime-host-manager';
+import type { RuntimeHostRouteResult } from '../main/runtime-host-contract';
+
+type RequestMethod = 'GET' | 'POST' | 'PUT' | 'DELETE';
+type RuntimeHostDomainId =
+  | 'gateway'
+  | 'sessions'
+  | 'plugins'
+  | 'providers'
+  | 'channels'
+  | 'skills'
+  | 'openclaw'
+  | 'platform'
+  | 'settings'
+  | 'runtime_host'
+  | 'toolchain'
+  | 'license'
+  | 'team_runtime'
+  | 'security'
+  | 'workbench'
+  | 'cron_usage'
+  | 'clawhub'
+  | 'default';
+
+interface RuntimeHostRoutePolicy {
+  domain: RuntimeHostDomainId;
+  matches: (method: RequestMethod, route: string) => boolean;
+  timeoutMs: number;
+  allowDuringBootstrap: boolean;
+  allowOnBootstrapError: boolean;
+  priority: 'interactive' | 'mutation' | 'background';
+}
+
+interface RuntimeHostForwardRequest {
+  method: RequestMethod;
+  route: string;
+  payload?: unknown;
+  timeoutMs?: number;
+  requestClass?: 'interactive' | 'mutation' | 'background';
+}
+
+const DEFAULT_TIMEOUT_MS = 15_000;
+
+const RUNTIME_HOST_ROUTE_POLICIES: RuntimeHostRoutePolicy[] = [
+  {
+    domain: 'gateway',
+    matches: (_, route) => route.startsWith('/api/gateway/'),
+    timeoutMs: 45_000,
+    allowDuringBootstrap: true,
+    allowOnBootstrapError: true,
+    priority: 'interactive',
+  },
+  {
+    domain: 'sessions',
+    matches: (_, route) => route.startsWith('/api/session/') || route.startsWith('/api/sessions/'),
+    timeoutMs: 30_000,
+    allowDuringBootstrap: true,
+    allowOnBootstrapError: true,
+    priority: 'interactive',
+  },
+  {
+    domain: 'plugins',
+    matches: (_, route) => route.startsWith('/api/plugins/'),
+    timeoutMs: 20_000,
+    allowDuringBootstrap: true,
+    allowOnBootstrapError: true,
+    priority: 'interactive',
+  },
+  {
+    domain: 'providers',
+    matches: (_, route) => route.startsWith('/api/provider-accounts/'),
+    timeoutMs: 20_000,
+    allowDuringBootstrap: true,
+    allowOnBootstrapError: true,
+    priority: 'interactive',
+  },
+  {
+    domain: 'channels',
+    matches: (_, route) => route.startsWith('/api/channels/'),
+    timeoutMs: 20_000,
+    allowDuringBootstrap: true,
+    allowOnBootstrapError: true,
+    priority: 'interactive',
+  },
+  {
+    domain: 'skills',
+    matches: (_, route) => route.startsWith('/api/skills/'),
+    timeoutMs: 20_000,
+    allowDuringBootstrap: true,
+    allowOnBootstrapError: true,
+    priority: 'interactive',
+  },
+  {
+    domain: 'openclaw',
+    matches: (_, route) => route.startsWith('/api/openclaw/'),
+    timeoutMs: 15_000,
+    allowDuringBootstrap: true,
+    allowOnBootstrapError: true,
+    priority: 'interactive',
+  },
+  {
+    domain: 'platform',
+    matches: (_, route) => route.startsWith('/api/platform/'),
+    timeoutMs: 30_000,
+    allowDuringBootstrap: true,
+    allowOnBootstrapError: true,
+    priority: 'interactive',
+  },
+  {
+    domain: 'settings',
+    matches: (_, route) => route.startsWith('/api/settings/'),
+    timeoutMs: 15_000,
+    allowDuringBootstrap: true,
+    allowOnBootstrapError: true,
+    priority: 'interactive',
+  },
+  {
+    domain: 'runtime_host',
+    matches: (_, route) => route.startsWith('/api/runtime-host/'),
+    timeoutMs: 30_000,
+    allowDuringBootstrap: true,
+    allowOnBootstrapError: true,
+    priority: 'interactive',
+  },
+  {
+    domain: 'toolchain',
+    matches: (_, route) => route.startsWith('/api/toolchain/'),
+    timeoutMs: 30_000,
+    allowDuringBootstrap: true,
+    allowOnBootstrapError: true,
+    priority: 'interactive',
+  },
+  {
+    domain: 'license',
+    matches: (_, route) => route.startsWith('/api/license/'),
+    timeoutMs: 15_000,
+    allowDuringBootstrap: true,
+    allowOnBootstrapError: true,
+    priority: 'interactive',
+  },
+  {
+    domain: 'team_runtime',
+    matches: (_, route) => route.startsWith('/api/team-runtime/'),
+    timeoutMs: 20_000,
+    allowDuringBootstrap: true,
+    allowOnBootstrapError: true,
+    priority: 'interactive',
+  },
+  {
+    domain: 'security',
+    matches: (_, route) => route.startsWith('/api/security/'),
+    timeoutMs: 30_000,
+    allowDuringBootstrap: true,
+    allowOnBootstrapError: true,
+    priority: 'interactive',
+  },
+  {
+    domain: 'workbench',
+    matches: (_, route) => route.startsWith('/api/workbench/'),
+    timeoutMs: 15_000,
+    allowDuringBootstrap: true,
+    allowOnBootstrapError: true,
+    priority: 'interactive',
+  },
+  {
+    domain: 'cron_usage',
+    matches: (_, route) => route.startsWith('/api/cron/') || route.startsWith('/api/usage/'),
+    timeoutMs: 20_000,
+    allowDuringBootstrap: true,
+    allowOnBootstrapError: true,
+    priority: 'interactive',
+  },
+  {
+    domain: 'clawhub',
+    matches: (_, route) => route.startsWith('/api/clawhub/'),
+    timeoutMs: 20_000,
+    allowDuringBootstrap: true,
+    allowOnBootstrapError: true,
+    priority: 'background',
+  },
+];
+
+function resolveRoutePolicy(method: RequestMethod, route: string): RuntimeHostRoutePolicy {
+  return RUNTIME_HOST_ROUTE_POLICIES.find((policy) => policy.matches(method, route)) ?? {
+    domain: 'default',
+    matches: () => true,
+    timeoutMs: DEFAULT_TIMEOUT_MS,
+    allowDuringBootstrap: false,
+    allowOnBootstrapError: false,
+    priority: 'interactive',
+  };
+}
+
+function buildUnavailableResult(message: string): RuntimeHostRouteResult {
+  return {
+    status: 503,
+    data: {
+      success: false,
+      error: message,
+    },
+  };
+}
+
+export async function forwardRuntimeHostRequest(
+  runtimeHost: RuntimeHostManager,
+  input: RuntimeHostForwardRequest,
+): Promise<RuntimeHostRouteResult> {
+  const policy = resolveRoutePolicy(input.method, input.route);
+  const state = runtimeHost.getState();
+
+  if (state.lifecycle === 'starting') {
+    return buildUnavailableResult(`Runtime host transport is starting (${policy.domain})`);
+  }
+
+  if (
+    state.lifecycle === 'idle'
+    || state.lifecycle === 'stopped'
+    || state.lifecycle === 'error'
+    || state.runtimeLifecycle === 'stopped'
+  ) {
+    return buildUnavailableResult(`Runtime host unavailable (${policy.domain})`);
+  }
+
+  if (state.runtimeLifecycle === 'booting' && !policy.allowDuringBootstrap) {
+    return buildUnavailableResult(`Runtime host is booting (${policy.domain})`);
+  }
+
+  if (state.runtimeLifecycle === 'error' && !policy.allowOnBootstrapError) {
+    return buildUnavailableResult(`Runtime host bootstrap failed (${policy.domain})`);
+  }
+
+  return await runtimeHost.request(
+    input.method,
+    input.route,
+    input.payload,
+    {
+      timeoutMs: typeof input.timeoutMs === 'number' && input.timeoutMs > 0
+        ? input.timeoutMs
+        : policy.timeoutMs,
+      requestClass: input.requestClass ?? policy.priority,
+    },
+  );
+}
