+    matches: (context) => shouldRunDataWarmup(context)
+      && context.gatewayOperational
+      && pathStartsWith(context.path, '/channels'),
+    key: () => 'channels',
+    run: async () => ensureRendererDomainSnapshot('channels', { intent: 'route', silent: true }),
+  },
+  {
+    id: 'subagents',
