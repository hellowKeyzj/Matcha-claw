+}
+
+function resolveNodeDirFromNpmCli(npmCliPath: string): string {
+  return path.win32.dirname(path.win32.dirname(path.win32.dirname(path.win32.dirname(npmCliPath))));
+}
+
+function resolveWindowsSafeNpmCliPath(
+  env: GatewayEnv,
+  pathExists: (pathname: string) => boolean,
+): string | null {
+  const inheritedNpmExecPath = typeof env.npm_execpath === 'string' ? env.npm_execpath.trim() : '';
+  if (inheritedNpmExecPath && isNpmCliPath(inheritedNpmExecPath) && pathExists(inheritedNpmExecPath)) {
+    return inheritedNpmExecPath;
+  }
+
+  for (const entry of getPathEnvValue(env).split(';')) {
+    const dir = entry.trim();
+    if (!dir) {
+      continue;
+    }
+    const candidate = path.win32.join(dir, 'node_modules', 'npm', 'bin', 'npm-cli.js');
+    if (pathExists(candidate)) {
+      return candidate;
+    }
+  }
+
+  return null;
+}
+
+export function withWindowsSafeNpmRuntimeEnv(
+  env: GatewayEnv,
+  options: {
+    platform?: NodeJS.Platform;
+    pathExists?: (pathname: string) => boolean;
+  } = {},
+): GatewayEnv {
+  const platform = options.platform ?? process.platform;
+  if (platform !== 'win32') {
+    return env;
+  }
+
+  const pathExists = options.pathExists ?? existsSync;
+  const npmCliPath = resolveWindowsSafeNpmCliPath(env, pathExists);
+  if (!npmCliPath) {
+    return env;
+  }
+
+  const nodeDir = resolveNodeDirFromNpmCli(npmCliPath);
+  const nodeExePath = path.win32.join(nodeDir, 'node.exe');
+  if (!pathExists(nodeExePath)) {
+    return env;
+  }
+
+  return {
+    ...prependPathEntry(env, nodeDir).env,
+    npm_execpath: npmCliPath,
+    MATCHACLAW_GATEWAY_SAFE_NODE_EXEC_PATH: nodeExePath,
+  };
+}
