+++ b/src/stores/license.ts
@@ -0,0 +1,268 @@
+import { create } from 'zustand';
+import { hostApiFetch } from '@/lib/host-api';
+
+export type LicenseValidationCode =
+  | 'valid'
+  | 'empty'
+  | 'format_invalid'
+  | 'service_unconfigured'
+  | 'network_error'
+  | 'server_rejected'
+  | 'cache_grace_valid'
+  | 'expired'
+  | 'device_mismatch'
+  | 'not_allowed'
+  | 'checksum_invalid';
+
+export type LicenseValidationCodeWithUnknown = LicenseValidationCode | 'unknown';
+
+export interface LicenseValidationResponse {
+  valid: boolean;
+  code: LicenseValidationCode;
+  normalizedKey?: string;
+  message?: string;
+}
+
+export interface LicenseGateSnapshot {
+  state: 'checking' | 'granted' | 'blocked';
+  reason: string;
+  checkedAtMs: number;
+  hasStoredKey: boolean;
+  hasUsableCache: boolean;
+  nextRevalidateAtMs: number | null;
+  lastValidation?: LicenseValidationResponse | null;
+  renewalAlert?: 'near_expiry_renew_failed' | null;
+}
+
+const LICENSE_REFRESH_MIN_GAP_MS = 10_000;
+
+let inflightBootstrapPromise: Promise<void> | null = null;
+let inflightRefreshPromise: Promise<void> | null = null;
+let lastRefreshAtMs = 0;
+
+function createInitialGateSnapshot(): LicenseGateSnapshot {
+  return {
+    state: 'checking',
+    reason: 'init',
+    checkedAtMs: 0,
+    hasStoredKey: false,
+    hasUsableCache: false,
+    nextRevalidateAtMs: null,
+    lastValidation: null,
+    renewalAlert: null,
+  };
+}
+
+interface LicenseStoreState {
+  gateSnapshot: LicenseGateSnapshot;
+  storedKey: string;
+  initialized: boolean;
+  bootstrapping: boolean;
+  refreshing: boolean;
+  mutating: boolean;
+  validationResult: LicenseValidationResponse | null;
+  validationCode: LicenseValidationCodeWithUnknown | null;
+  validationError: string | null;
+  init: () => Promise<void>;
+  refreshGateSnapshot: (options?: { force?: boolean }) => Promise<void>;
+  setDraftKey: (value: string) => void;
+  validateKey: (inputKey?: string) => Promise<LicenseValidationResponse | null>;
+  forceRevalidate: () => Promise<LicenseValidationResponse | null>;
+  clearStored: () => Promise<void>;
+  clearValidationState: () => void;
+}
+
+export const useLicenseStore = create<LicenseStoreState>((set, get) => ({
+  gateSnapshot: createInitialGateSnapshot(),
+  storedKey: '',
+  initialized: false,
+  bootstrapping: false,
+  refreshing: false,
+  mutating: false,
+  validationResult: null,
+  validationCode: null,
+  validationError: null,
+
+  init: async () => {
+    if (get().initialized) {
+      return;
+    }
+    if (inflightBootstrapPromise) {
+      await inflightBootstrapPromise;
+      return;
+    }
+
+    set({ bootstrapping: true, validationError: null });
+    const task = (async () => {
+      try {
+        const [storedKeyPayload, gateSnapshot] = await Promise.all([
+          hostApiFetch<{ key: string | null }>('/api/license/stored-key'),
+          hostApiFetch<LicenseGateSnapshot>('/api/license/gate'),
+        ]);
+        const storedKey = typeof storedKeyPayload?.key === 'string'
+          ? storedKeyPayload.key.trim()
+          : '';
+        const validationResult = gateSnapshot.lastValidation ?? null;
+        set({
+          storedKey,
+          gateSnapshot,
+          validationResult,
+          validationCode: validationResult?.code ?? null,
+          initialized: true,
+          bootstrapping: false,
+          validationError: null,
+        });
+        lastRefreshAtMs = Date.now();
+      } catch (error) {
+        set({
+          initialized: true,
+          bootstrapping: false,
+          validationError: error instanceof Error ? error.message : String(error),
+        });
+      }
+    })();
+
+    inflightBootstrapPromise = task;
+    try {
+      await task;
+    } finally {
+      if (inflightBootstrapPromise === task) {
+        inflightBootstrapPromise = null;
+      }
+    }
+  },
+
+  refreshGateSnapshot: async (options) => {
+    const force = options?.force === true;
+    if (inflightRefreshPromise) {
+      await inflightRefreshPromise;
+      return;
+    }
+    if (!force && Date.now() - lastRefreshAtMs < LICENSE_REFRESH_MIN_GAP_MS) {
+      return;
+    }
+
+    set({ refreshing: true, validationError: null });
+    const task = (async () => {
+      try {
+        const gateSnapshot = await hostApiFetch<LicenseGateSnapshot>('/api/license/gate');
+        const validationResult = gateSnapshot.lastValidation ?? get().validationResult;
+        set((state) => ({
+          gateSnapshot,
+          validationResult,
+          validationCode: validationResult?.code ?? state.validationCode,
+          refreshing: false,
+          validationError: null,
+        }));
+        lastRefreshAtMs = Date.now();
+      } catch (error) {
+        set({
+          refreshing: false,
+          validationError: error instanceof Error ? error.message : String(error),
+        });
+      }
+    })();
+
+    inflightRefreshPromise = task;
+    try {
+      await task;
+    } finally {
+      if (inflightRefreshPromise === task) {
+        inflightRefreshPromise = null;
+      }
+    }
+  },
+
+  setDraftKey: (value) => {
+    set({
+      storedKey: value,
+      validationResult: null,
+      validationCode: null,
+      validationError: null,
+    });
+  },
+
+  validateKey: async (inputKey) => {
+    const key = typeof inputKey === 'string' ? inputKey : get().storedKey;
+    set({ mutating: true, validationError: null });
+    try {
+      const result = await hostApiFetch<LicenseValidationResponse>('/api/license/validate', {
+        method: 'POST',
+        body: JSON.stringify({ key }),
+      });
+      await get().refreshGateSnapshot({ force: true });
+      set({
+        storedKey: result.normalizedKey?.trim() || key.trim(),
+        validationResult: result,
+        validationCode: result.code,
+        mutating: false,
+        validationError: null,
+      });
+      return result;
+    } catch (error) {
+      set({
+        validationResult: null,
+        validationCode: 'unknown',
+        mutating: false,
+        validationError: error instanceof Error ? error.message : String(error),
+      });
+      return null;
+    }
+  },
+
+  forceRevalidate: async () => {
+    set({ mutating: true, validationError: null });
+    try {
+      const result = await hostApiFetch<LicenseValidationResponse>('/api/license/revalidate', {
+        method: 'POST',
+      });
+      await get().refreshGateSnapshot({ force: true });
+      set((state) => ({
+        storedKey: result.normalizedKey?.trim() || state.storedKey,
+        validationResult: result,
+        validationCode: result.code,
+        mutating: false,
+        validationError: null,
+      }));
+      return result;
+    } catch (error) {
+      set({
+        validationResult: null,
+        validationCode: 'unknown',
+        mutating: false,
+        validationError: error instanceof Error ? error.message : String(error),
+      });
+      return null;
+    }
+  },
+
+  clearStored: async () => {
+    set({ mutating: true, validationError: null });
+    try {
+      await hostApiFetch('/api/license/clear', { method: 'POST' });
+      await get().refreshGateSnapshot({ force: true });
+      set({
+        storedKey: '',
+        validationResult: null,
+        validationCode: null,
+        mutating: false,
+        validationError: null,
+      });
+    } catch (error) {
+      const message = error instanceof Error ? error.message : String(error);
+      set({
+        mutating: false,
+        validationError: message,
+      });
+      throw error;
+    }
+  },
+
+  clearValidationState: () => {
+    set({
+      validationResult: null,
+      validationCode: null,
+      validationError: null,
+    });
+  },
+}));
