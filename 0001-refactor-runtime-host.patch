+import { create } from 'zustand';
+
+export type AppBootstrapDomainId =
+  | 'settings'
+  | 'gateway'
+  | 'updates'
+  | 'route-chunk'
+  | 'route-neighborhood'
+  | 'providers'
+  | 'skills'
+  | 'chat-sessions'
+  | 'dashboard-usage'
+  | 'tasks'
+  | 'task-center-runtime'
+  | 'channels'
+  | 'plugins'
+  | 'subagents'
+  | 'subagent-models'
+  | 'subagent-templates'
+  | 'subagent-template-catalog'
+  | 'teams-runtime'
+  | 'team-runtime-current'
+  | 'team-chat-viewport'
+  | 'chat-task-inbox-runtime'
+  | 'license'
+  | 'cron-jobs'
+  | 'security-policy'
+  | 'security-rule-catalog'
+  | 'security-audits';
+
+export type AppBootstrapDomainStatus = 'idle' | 'running' | 'ready' | 'error';
+
+export interface AppBootstrapDomainState {
+  status: AppBootstrapDomainStatus;
+  updatedAt: number;
+  lastReason: string | null;
+  error: string | null;
+}
+
+interface AppBootstrapStoreState {
+  domains: Record<AppBootstrapDomainId, AppBootstrapDomainState>;
+  markRunning: (domain: AppBootstrapDomainId, reason: string) => void;
+  markReady: (domain: AppBootstrapDomainId, reason: string) => void;
+  markError: (domain: AppBootstrapDomainId, reason: string, error: string) => void;
+}
+
+function createDomainState(): AppBootstrapDomainState {
+  return {
+    status: 'idle',
+    updatedAt: 0,
+    lastReason: null,
+    error: null,
+  };
+}
+
+function buildInitialDomains(): Record<AppBootstrapDomainId, AppBootstrapDomainState> {
+  return {
+    settings: createDomainState(),
+    gateway: createDomainState(),
+    updates: createDomainState(),
+    'route-chunk': createDomainState(),
+    'route-neighborhood': createDomainState(),
+    providers: createDomainState(),
+    skills: createDomainState(),
+    'chat-sessions': createDomainState(),
+    'dashboard-usage': createDomainState(),
+    tasks: createDomainState(),
+    'task-center-runtime': createDomainState(),
+    channels: createDomainState(),
+    plugins: createDomainState(),
+    subagents: createDomainState(),
+    'subagent-models': createDomainState(),
+    'subagent-templates': createDomainState(),
+    'subagent-template-catalog': createDomainState(),
+    'teams-runtime': createDomainState(),
+    'team-runtime-current': createDomainState(),
+    'team-chat-viewport': createDomainState(),
+    'chat-task-inbox-runtime': createDomainState(),
+    license: createDomainState(),
+    'cron-jobs': createDomainState(),
+    'security-policy': createDomainState(),
+    'security-rule-catalog': createDomainState(),
+    'security-audits': createDomainState(),
+  };
+}
+
+function patchDomainState(
+  domains: Record<AppBootstrapDomainId, AppBootstrapDomainState>,
+  domain: AppBootstrapDomainId,
+  patch: Partial<AppBootstrapDomainState>,
+): Record<AppBootstrapDomainId, AppBootstrapDomainState> {
+  return {
+    ...domains,
+    [domain]: {
+      ...domains[domain],
+      ...patch,
+      updatedAt: Date.now(),
+    },
+  };
+}
+
+export const useAppBootstrapStore = create<AppBootstrapStoreState>((set) => ({
+  domains: buildInitialDomains(),
+  markRunning: (domain, reason) => {
+    set((state) => ({
+      domains: patchDomainState(state.domains, domain, {
+        status: 'running',
+        lastReason: reason,
+        error: null,
+      }),
+    }));
+  },
+  markReady: (domain, reason) => {
+    set((state) => ({
+      domains: patchDomainState(state.domains, domain, {
+        status: 'ready',
+        lastReason: reason,
+        error: null,
+      }),
+    }));
+  },
+  markError: (domain, reason, error) => {
+    set((state) => ({
+      domains: patchDomainState(state.domains, domain, {
+        status: 'error',
+        lastReason: reason,
+        error,
+      }),
+    }));
+  },
+}));
