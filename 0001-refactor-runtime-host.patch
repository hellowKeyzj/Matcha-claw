+function readGatewayState() {
+  const store = useGatewayStore as typeof useGatewayStore & {
+    getState?: () => ReturnType<typeof useGatewayStore.getState>;
+  };
+  if (typeof store.getState === 'function') {
+    return store.getState();
+  }
+  return useGatewayStore((state) => state);
+}
+
+function extractTeamIdFromPath(path?: string): string | null {
+  if (!path) {
+    return null;
+  }
+  const segments = path.split('/').filter(Boolean);
+  if (segments[0] !== 'teams' || segments.length < 2) {
+    return null;
+  }
+  const teamId = segments[1]?.trim();
+  return teamId ? decodeURIComponent(teamId) : null;
+}
+
+function requireTeamId(context?: RendererDomainContext): string | null {
+  return extractTeamIdFromPath(context?.path);
+}
+
+async function ensureTaskCenterSnapshot(): Promise<void> {
