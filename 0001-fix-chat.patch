+import type { TFunction } from 'i18next';
+import { localizeGatewayIssue } from './chat-gateway-status-view';
+import { hasVisibleRuntimeError } from '@/stores/chat/runtime-error-view';
+import type {
+  ChatRuntimeErrorDismissMarker,
+  ChatSessionRuntimeState,
+} from '@/stores/chat';
+
+const ACTIVE_RUN_DISCONNECTED_ERROR = 'The active run disconnected before a terminal event was received.';
+
+export function resolveVisibleChatRuntimeError(input: {
+  runtime: Pick<ChatSessionRuntimeState, 'lastError' | 'lastIssue' | 'updatedAt'>;
+  dismissedMarker: ChatRuntimeErrorDismissMarker | undefined;
+  t: TFunction<'chat'>;
+}): string | null {
+  if (!hasVisibleRuntimeError({
+    runtime: input.runtime,
+    dismissedMarker: input.dismissedMarker,
+  })) {
+    return null;
+  }
+  const localizedRuntimeIssue = localizeGatewayIssue(input.runtime.lastIssue ?? undefined, input.t);
+  const effectiveRuntimeError = localizedRuntimeIssue ?? input.runtime.lastError;
+  if (!effectiveRuntimeError) {
+    return null;
+  }
+  if (effectiveRuntimeError === ACTIVE_RUN_DISCONNECTED_ERROR) {
+    return input.t('errors.activeRunDisconnected');
+  }
+  return effectiveRuntimeError;
+}
