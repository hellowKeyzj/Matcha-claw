{
  "id": "team-runtime",
  "name": "Team Runtime",
  "version": "0.1.0",
  "category": "automation",
  "description": "Production TeamSkill runtime for MatchaClaw multi-agent workflows.",
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "gatewayMethods": [],
    "tools": [
      "team_submit_workflow_plan",
      "team_complete_task",
      "team_send_message",
      "team_request_approval"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["availableSkills", "availableTools"],
    "properties": {
      "storageRoot": {
        "type": "string"
      },
      "defaultChannel": {
        "type": "string"
      },
      "availableSkills": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "availableTools": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
