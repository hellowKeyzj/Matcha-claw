{
  "preset": "balanced",
  "defaultAction": "confirm",
  "approvalTimeoutMs": 604800000,
  "allowTools": [
    "task_create",
    "task_set_plan_markdown",
    "task_bind_session",
    "task_request_user_input",
    "task_wait_approval",
    "task_mark_failed",
    "task_list",
    "task_get",
    "task_resume",
    "sessions_list",
    "memory_get",
    "memory_search"
  ],
  "confirmTools": [
    "system.run",
    "nodes.run",
    "fs.write_file",
    "fs.delete_file",
    "fs.remove",
    "http.request"
  ],
  "denyTools": [
    "system.disable_guardian",
    "security.disable_guard"
  ],
  "allowPathPrefixes": [],
  "allowDomains": [],
  "allowCommandExecution": true,
  "allowDependencyInstall": false,
  "confirmStrategy": "session",
  "capabilities": [
    "CAP_READ_LOCAL_FILES",
    "CAP_WRITE_LOCAL_FILES",
    "CAP_EXECUTE_COMMAND",
    "CAP_NETWORK_REQUEST"
  ],
  "networkUnknownAction": "confirm",
  "sensitivePathAction": "confirm",
  "highRiskAction": "confirm"
}
