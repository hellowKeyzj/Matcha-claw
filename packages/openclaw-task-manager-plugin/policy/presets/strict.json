{
  "preset": "strict",
  "defaultAction": "deny",
  "allowCommandExecution": false,
  "allowDependencyInstall": false,
  "confirmStrategy": "every_time",
  "capabilities": [
    "CAP_READ_LOCAL_FILES",
    "CAP_NETWORK_REQUEST"
  ],
  "networkUnknownAction": "confirm",
  "sensitivePathAction": "deny",
  "highRiskAction": "deny"
}
