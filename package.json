{
  "name": "clawx",
  "version": "1.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@discordjs/opus",
      "@whiskeysockets/baileys",
      "electron",
      "esbuild",
      "koffi",
      "node-llama-cpp",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ],
    "overrides": {
      "isbinaryfile": "^5.0.0"
    },
    "supportedArchitectures": {
      "os": [
        "current"
      ],
      "cpu": [
        "x64",
        "arm64"
      ]
    }
  },
  "description": "MatchaClaw - Graphical AI Assistant based on OpenClaw",
  "main": "dist-electron/main/index.js",
  "author": "MatchaClaw Team",
  "license": "MIT",
  "private": true,
  "scripts": {
    "init": "pnpm install && pnpm run uv:download",
    "dev": "pnpm run build:runtime-host-process && vite",
    "build": "pnpm run build:runtime-host-process && vite build && zx scripts/bundle-openclaw.mjs && zx scripts/bundle-openclaw-plugins.mjs && zx scripts/bundle-preinstalled-skills.mjs && electron-builder",
    "build:vite": "vite build",
    "build:runtime-host-process": "node scripts/build-runtime-host-process.mjs",
    "build:openclaw-local-plugins": "node scripts/build-local-openclaw-plugins.mjs",
    "bundle:openclaw-plugins": "zx scripts/bundle-openclaw-plugins.mjs",
    "download:minilm-model": "node packages/memory-lancedb-pro/scripts/download-local-minilm.mjs",
    "bundle:preinstalled-skills": "zx scripts/bundle-preinstalled-skills.mjs",
    "lint": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "pnpm run build:vite && playwright test",
    "test:e2e:headed": "pnpm run build:vite && playwright test --headed",
    "test:contract": "vitest run tests/contract",
    "check:trait-boundary": "node scripts/check-trait-boundary.mjs",
    "check:main-api-boundary": "node scripts/check-main-api-boundary.mjs",
    "check:openclaw-plugin-inputs": "node scripts/check-openclaw-plugin-inputs.mjs",
    "check:openclaw-plugin-mirrors": "node scripts/check-openclaw-plugin-mirrors.mjs",
    "templates:catalog": "node scripts/generate-subagent-template-catalog.mjs",
    "templates:i18n": "node scripts/generate-subagent-template-i18n.mjs",
    "uv:download": "zx scripts/download-bundled-uv.mjs",
    "uv:download:mac": "zx scripts/download-bundled-uv.mjs --platform=mac",
    "uv:download:win": "zx scripts/download-bundled-uv.mjs --platform=win",
    "uv:download:linux": "zx scripts/download-bundled-uv.mjs --platform=linux",
    "uv:download:all": "zx scripts/download-bundled-uv.mjs --all",
    "node:download:win": "zx scripts/download-bundled-node.mjs --platform=win",
    "prep:win-binaries": "pnpm run uv:download:win && pnpm run node:download:win",
    "icons": "zx scripts/generate-icons.mjs",
    "package": "pnpm run check:openclaw-plugin-inputs && pnpm run build:runtime-host-process && vite build && zx scripts/bundle-openclaw.mjs && zx scripts/bundle-openclaw-plugins.mjs && pnpm run check:openclaw-plugin-mirrors && zx scripts/bundle-preinstalled-skills.mjs && electron-builder",
    "package:mac": "pnpm run check:openclaw-plugin-inputs && pnpm run build:runtime-host-process && vite build && zx scripts/bundle-openclaw.mjs && zx scripts/bundle-openclaw-plugins.mjs && pnpm run check:openclaw-plugin-mirrors && zx scripts/bundle-preinstalled-skills.mjs && electron-builder --mac",
    "package:mac:local": "SKIP_PREINSTALLED_SKILLS=1 pnpm run check:openclaw-plugin-inputs && pnpm run build:runtime-host-process && vite build && zx scripts/bundle-openclaw.mjs && zx scripts/bundle-openclaw-plugins.mjs && pnpm run check:openclaw-plugin-mirrors && zx scripts/bundle-preinstalled-skills.mjs && electron-builder --mac",
    "package:win": "pnpm run check:openclaw-plugin-inputs && pnpm run prep:win-binaries && pnpm run build:runtime-host-process && vite build && zx scripts/bundle-openclaw.mjs && zx scripts/bundle-openclaw-plugins.mjs && pnpm run check:openclaw-plugin-mirrors && zx scripts/bundle-preinstalled-skills.mjs && electron-builder --win",
    "package:linux": "pnpm run check:openclaw-plugin-inputs && pnpm run build:runtime-host-process && vite build && zx scripts/bundle-openclaw.mjs && zx scripts/bundle-openclaw-plugins.mjs && pnpm run check:openclaw-plugin-mirrors && zx scripts/bundle-preinstalled-skills.mjs && electron-builder --linux",
    "release": "pnpm run uv:download && pnpm run build:runtime-host-process && vite build && zx scripts/bundle-openclaw.mjs && zx scripts/bundle-openclaw-plugins.mjs && zx scripts/bundle-preinstalled-skills.mjs && electron-builder --publish always",
    "version:patch": "pnpm version patch",
    "version:minor": "pnpm version minor",
    "version:major": "pnpm version major",
    "postversion": "git push && git push --tags"
  },
  "dependencies": {
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@matchaclaw/plugins-sdk": "workspace:*",
    "@slack/bolt": "^4.6.0",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "clawhub": "^0.5.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "ms": "^2.1.3",
    "qrcode": "1.5.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@aws-sdk/client-bedrock": "3.1020.0",
    "@eslint/js": "^10.0.1",
    "@larksuite/openclaw-lark": "2026.3.29",
    "@playwright/test": "^1.58.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sinclair/typebox": "^0.34.48",
    "@slack/web-api": "^7.15.0",
    "@soimy/dingtalk": "3.5.1",
    "@tencent-connect/openclaw-qqbot": "1.6.6",
    "@tencent-weixin/openclaw-weixin": "2.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@wecom/wecom-openclaw-plugin": "2026.3.26",
    "autoprefixer": "^10.4.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "framer-motion": "^12.34.2",
    "globals": "^17.3.0",
    "i18next": "^25.8.11",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.563.0",
    "markdown-it": "^14.1.1",
    "memory-lancedb-pro": "workspace:*",
    "openclaw": "2026.4.1",
    "png2icons": "^2.0.1",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.18",
    "zustand": "^5.0.11",
    "zx": "^8.8.5"
  },
  "packageManager": "pnpm@10.29.2+sha512.bef43fa759d91fd2da4b319a5a0d13ef7a45bb985a3d7342058470f9d2051a3ba8674e629672654686ef9443ad13a82da2beb9eeb3e0221c87b8154fff9d74b8"
}
